---
import MainLayout from '../../layouts/MainLayout.astro';
import { getNewsBySlug, getNewsSlugs, getSiteSetting } from '../../lib/api';

export async function getStaticPaths() {
  const slugs = await getNewsSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug = '' } = Astro.params;
const [entry, siteSetting] = await Promise.all([getNewsBySlug(slug), getSiteSetting()]);

if (!entry) {
  Astro.response.status = 404;
}

function formatDate(value: string | null) {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }).format(date);
}

const publishedDate = formatDate(entry?.publishedDate ?? null);
const pageTitle = entry?.seo?.metaTitle ?? entry?.title ?? siteSetting?.siteName ?? 'News';
const pageDescription = entry?.seo?.metaDescription ?? siteSetting?.siteDescription ?? null;
---

<MainLayout title={pageTitle} seo={entry?.seo} siteSetting={siteSetting}>
  {entry ? (
    <article class="mx-auto max-w-7xl px-4 py-14 md:px-6 md:py-20">
      <a class="inline-flex text-sm font-semibold text-red-700 transition hover:text-red-800" href="/news">Back to news</a>

      <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1.02fr)_minmax(20rem,0.98fr)]">
        <div>
          <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">
            <span class="rounded-full bg-red-700 px-3 py-1 text-white">News Update</span>
            {publishedDate && <span>{publishedDate}</span>}
          </div>
          <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight text-stone-900 md:text-5xl lg:text-6xl">
            {entry.title}
          </h1>
          {pageDescription && <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-600">{pageDescription}</p>}
        </div>

        <div class="overflow-hidden rounded-[1.75rem] border border-stone-200 bg-white shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          {entry.coverImage?.url ? (
            <img class="h-full w-full object-cover" src={entry.coverImage.url} alt={entry.coverImage.alternativeText ?? entry.title} loading="eager" />
          ) : (
            <div class="grid min-h-[24rem] place-items-center bg-stone-50 p-8 text-center">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Editorial Cover</p>
                <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">{entry.title}</h2>
                <p class="mt-4 max-w-sm text-sm leading-7 text-stone-600">
                  Attach a cover image in Strapi to give this article a stronger editorial lead.
                </p>
              </div>
            </div>
          )}
        </div>
      </section>

      <section class="mt-10 rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Article</p>
        <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Published content</h2>
        {entry.content ? (
          <div
            class="prose prose-stone mt-6 max-w-4xl prose-headings:font-semibold prose-p:leading-8 prose-a:text-red-700"
            set:html={entry.content}
          ></div>
        ) : (
          <p class="mt-6 max-w-3xl text-base leading-8 text-stone-600">No article body is available for this entry yet.</p>
        )}
      </section>

      <section class="mt-6 rounded-[2rem] border border-neutral-900 bg-neutral-950 px-6 py-10 text-white shadow-[0_28px_80px_-32px_rgba(12,10,9,0.72)] md:px-10">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-500">Continue Exploring</p>
        <h2 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">Need help applying this to your website?</h2>
        <p class="mt-5 max-w-3xl text-base leading-8 text-white/70">
          Move from editorial examples into implementation planning, content modeling, or frontend delivery work.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn-primary !rounded-md !px-7 !py-3.5" href="/contact">Contact Us</a>
          <a class="btn-secondary !rounded-md !border-white/20 !bg-white/5 !px-7 !py-3.5 !text-white" href="/projects">
            See Projects
          </a>
        </div>
      </section>
    </article>
  ) : (
    <section class="mx-auto max-w-5xl px-4 py-14 md:px-6 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">404</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-5xl">News article not found</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-600">The requested news slug is not available from Strapi.</p>
      <a class="mt-6 inline-flex text-sm font-semibold text-red-700 transition hover:text-red-800" href="/news">Back to news</a>
    </section>
  )}
</MainLayout>
