---
import MainLayout from '../../layouts/MainLayout.astro';
import { getNews, getPageBySlug, getSiteSetting } from '../../lib/api';

const [page, siteSetting, news] = await Promise.all([getPageBySlug('news'), getSiteSetting(), getNews()]);
const title = page?.seo?.metaTitle ?? page?.title ?? siteSetting?.siteName ?? 'News';
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  <section class="border-b border-gray-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-6 md:py-20">
      <div class="max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">News & Events</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">
          {page?.sections?.find((section) => section.type === 'hero')?.title ?? 'Editorial updates and institutional announcements from the same content system'}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
          {page?.sections?.find((section) => section.type === 'hero')?.description ??
            'News entries now sit inside the same portal-style presentation model used across the rest of the migrated theme.'}
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {news.map((item) => (
        <article class="rounded-[1.75rem] border border-stone-200 bg-white p-7 shadow-sm">
          <span class="rounded-full border border-red-700 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-red-700">
            {item.publishedDate ?? 'News'}
          </span>
          <h2 class="mt-5 text-2xl font-semibold text-stone-900">{item.title}</h2>
          <p class="mt-4 text-sm leading-7 text-stone-600">
            {item.content?.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 150) ?? 'Published update from the CONC editorial system.'}
          </p>
          <a class="mt-6 inline-flex items-center text-sm font-semibold text-red-700" href={`/news/${item.slug}`}>
            Read article
            <span class="ml-2">→</span>
          </a>
        </article>
      ))}
    </div>
  </section>
</MainLayout>
