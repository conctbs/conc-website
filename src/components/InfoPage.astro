---
interface SectionItem {
  title: string;
  body: string;
}

const {
  eyebrow,
  title,
  intro,
  sections = [],
  lastUpdated = null,
} = Astro.props as {
  eyebrow: string;
  title: string;
  intro: string;
  sections?: SectionItem[];
  lastUpdated?: string | null;
};
---

<style>
  .info-page {
    padding: 4rem 0 1rem;
  }

  .info-hero {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--line);
  }

  .info-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .info-title {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    line-height: 0.92;
  }

  .info-intro {
    max-width: 48rem;
    margin: 1.25rem 0 0;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .info-meta {
    margin-top: 1rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    padding: 2rem 0 3rem;
  }

  .info-card {
    padding: 1.5rem;
    border: 1px solid rgba(127, 29, 29, 0.14);
    border-radius: var(--radius-card);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.94)),
      linear-gradient(135deg, rgba(185, 28, 28, 0.12), rgba(15, 15, 16, 0.02));
    box-shadow: var(--shadow-soft);
  }

  .info-card h2 {
    margin: 0 0 0.85rem;
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .info-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  @media (max-width: 900px) {
    .info-page {
      padding-top: 2rem;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="info-page">
  <div class="info-hero">
    <div class="info-eyebrow">{eyebrow}</div>
    <h1 class="info-title">{title}</h1>
    <p class="info-intro">{intro}</p>
    {lastUpdated && <div class="info-meta">Last updated: {lastUpdated}</div>}
  </div>

  <div class="info-grid">
    {sections.map((section) => (
      <article class="info-card">
        <h2>{section.title}</h2>
        <p>{section.body}</p>
      </article>
    ))}
  </div>
</section>
