---
import MainLayout from '../../layouts/MainLayout.astro';
import PageCover from '../../components/PageCover.astro';
import { getProgramBySlug, getProgramSlugs, getSiteSetting } from '../../lib/api';
import { programDetailContent } from '../../lib/program-detail-content';

const programHeroImageBySlug: Record<string, { src: string; alt: string }> = {
  'strategic-content-operations-bootcamp': {
    src: '/programs/strategic-content-operations-bootcamp-hero.png',
    alt: 'Strategic Content Operations Bootcamp course illustration',
  },
  'executive-communication-design-for-digital-teams': {
    src: '/programs/executive-communication-design-for-digital-teams.png',
    alt: 'Executive Communication Design for Digital Teams course illustration',
  },
};

export async function getStaticPaths() {
  const slugs = await getProgramSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug = '' } = Astro.params;
const [siteSetting, program] = await Promise.all([getSiteSetting(), getProgramBySlug(slug)]);
const sampleContent = program ? programDetailContent[program.slug] ?? null : null;
const heroImage = program ? programHeroImageBySlug[program.slug] ?? null : null;
const backHref = program?.isForumEvent ? '/life-long-learning/conc-thammasat-forum' : '/programs';
const backLabel = program?.isForumEvent ? 'Back to CONC Thammasat Forum' : 'Back to programs';

if (!program) {
  Astro.response.status = 404;
}
---

<MainLayout title={program?.seo?.metaTitle ?? program?.title ?? 'Program'} seo={program?.seo} siteSetting={siteSetting}>
  {program ? (
    <article class="mx-auto max-w-7xl px-4 py-14 md:px-6 md:py-20">
      <a class="inline-flex text-sm font-semibold text-red-700 transition hover:text-red-800" href={backHref}>{backLabel}</a>

      <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1.08fr)_minmax(20rem,0.92fr)]">
        <div>
          <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">
            <span class="rounded-full bg-red-700 px-3 py-1 text-white">{program.forumSeriesLabel ?? program.category ?? 'Program'}</span>
            {program.format && <span>{program.format}</span>}
            {program.dateLabel && <span>{program.dateLabel}</span>}
          </div>
          <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight text-stone-900 md:text-5xl lg:text-6xl">
            {program.title}
          </h1>
          {program.tagline && <p class="mt-4 max-w-3xl text-xl leading-8 text-red-700">{program.tagline}</p>}
          <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-600">{program.summary}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            {program.registrationEnabled ? (
              <a class="btn-primary !rounded-md !px-7 !py-3.5" href={`/programs/register/${program.slug}`}>Register</a>
            ) : (
              <span class="rounded-full border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold uppercase tracking-[0.14em] text-red-700">
                Registration closed
              </span>
            )}
            <a class="btn-secondary !rounded-md !border-stone-300 !px-7 !py-3.5 !text-stone-800" href="/contact">
              Contact Us
            </a>
          </div>
        </div>

        <div class="grid gap-6">
          {program.coverImage?.url ? (
            <figure class="overflow-hidden rounded-[1.75rem] border border-stone-200 bg-white shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)]">
              <img
                class="h-full w-full object-cover"
                src={program.coverImage.url}
                alt={program.coverImage.alternativeText ?? program.title}
                loading="eager"
              />
            </figure>
          ) : heroImage ? (
            <figure class="overflow-hidden rounded-[1.75rem] border border-stone-200 bg-white shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)]">
              <img
                class="h-full w-full object-cover"
                src={heroImage.src}
                alt={heroImage.alt}
                loading="eager"
              />
            </figure>
          ) : (
            <PageCover eyebrow={program.category ?? 'Program'} title={program.title} theme="programs" />
          )}
          <aside class="rounded-[1.75rem] border border-stone-200 bg-stone-100 p-6 text-stone-900 shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)]">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-500">Program overview</p>
            <div class="mt-6 grid gap-4">
              <div class="rounded-2xl border border-stone-200 bg-white p-4">
                <p class="text-sm text-stone-500">Audience</p>
                <p class="mt-2 text-base font-medium text-stone-900">{program.audience}</p>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl border border-stone-200 bg-white p-4">
                  <p class="text-sm text-stone-500">Starts</p>
                  <p class="mt-2 text-base font-medium text-stone-900">{program.startsAt ?? 'TBC'}</p>
                </div>
                <div class="rounded-2xl border border-stone-200 bg-white p-4">
                  <p class="text-sm text-stone-500">Location</p>
                  <p class="mt-2 text-base font-medium text-stone-900">{program.location}</p>
                </div>
                <div class="rounded-2xl border border-stone-200 bg-white p-4">
                  <p class="text-sm text-stone-500">Fee</p>
                  <p class="mt-2 text-base font-medium text-stone-900">{program.fee}</p>
                </div>
                <div class="rounded-2xl border border-stone-200 bg-white p-4">
                  <p class="text-sm text-stone-500">Duration</p>
                  <p class="mt-2 text-base font-medium text-stone-900">{program.duration}</p>
                </div>
              </div>
              <div class="rounded-2xl border border-stone-200 bg-white p-4">
                <p class="text-sm text-stone-500">Seats</p>
                <p class="mt-2 text-base font-medium text-stone-900">{program.seats ? `${program.seats} seats` : 'TBC'}</p>
              </div>
              {!program.registrationEnabled && (
                <div class="rounded-2xl border border-red-200 bg-red-50 p-4">
                  <p class="text-sm text-red-600">Registration</p>
                  <p class="mt-2 text-base font-medium text-red-700">Closed</p>
                </div>
              )}
            </div>
          </aside>
        </div>
      </section>

      <section class="mt-10 grid gap-6 lg:grid-cols-2">
        <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Program Overview</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">What participants will work through</h2>
          <div class="mt-5 space-y-4 text-base leading-8 text-stone-600">
            {program.overview.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>
        <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Learning Outcomes</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Expected takeaways</h2>
          <ul class="mt-5 space-y-3 pl-5 text-base leading-8 text-stone-600 marker:text-red-700">
            {program.outcomes.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </section>

      {(program.speakers.length > 0 || program.agendaItems.length > 0) && (
        <section class="mt-6 grid gap-6 lg:grid-cols-2">
          {program.speakers.length > 0 && (
            <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Speakers</p>
              <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Session contributors</h2>
              <div class="mt-6 grid gap-4">
                {program.speakers.map((speaker) => (
                  <div class="rounded-2xl border border-stone-200 bg-stone-50 p-5">
                    <p class="text-lg font-semibold text-stone-900">{speaker.name}</p>
                    <p class="mt-1 text-sm font-medium text-red-700">{[speaker.role, speaker.organization].filter(Boolean).join(' | ')}</p>
                    {speaker.bio && <p class="mt-3 text-sm leading-7 text-stone-600">{speaker.bio}</p>}
                  </div>
                ))}
              </div>
            </article>
          )}
          {program.agendaItems.length > 0 && (
            <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Agenda</p>
              <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Forum flow</h2>
              <div class="mt-6 grid gap-4">
                {program.agendaItems.map((item) => (
                  <div class="rounded-2xl border border-stone-200 bg-stone-50 p-5">
                    {item.timeLabel && <p class="text-xs font-semibold uppercase tracking-[0.16em] text-red-700">{item.timeLabel}</p>}
                    <p class="mt-2 text-lg font-semibold text-stone-900">{item.title}</p>
                    {item.speakerName && <p class="mt-1 text-sm font-medium text-stone-500">{item.speakerName}</p>}
                    {item.description && <p class="mt-3 text-sm leading-7 text-stone-600">{item.description}</p>}
                  </div>
                ))}
              </div>
            </article>
          )}
        </section>
      )}

      {program.gallery.length > 0 && (
        <section class="mt-6 rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Gallery</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Event visuals</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {program.gallery.map((image) => (
              image?.url ? <img class="h-64 w-full rounded-2xl object-cover" src={image.url} alt={image.alternativeText ?? program.title} /> : null
            ))}
          </div>
        </section>
      )}

      {sampleContent && (
        <section class="mt-6 grid gap-6 lg:grid-cols-2">
          <article class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.18)]">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Highlights</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">{sampleContent.highlightTitle}</h2>
            <ul class="mt-5 space-y-3 pl-5 text-base leading-8 text-stone-600 marker:text-red-700">
              {sampleContent.highlights.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.18)]">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Agenda</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">{sampleContent.agendaTitle}</h2>
            <ul class="mt-5 space-y-3 pl-5 text-base leading-8 text-stone-600 marker:text-red-700">
              {sampleContent.agenda.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)] lg:col-span-2">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Deliverables</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">{sampleContent.deliverablesTitle}</h2>
            <ul class="mt-5 space-y-3 pl-5 text-base leading-8 text-stone-600 marker:text-red-700">
              {sampleContent.deliverables.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </section>
      )}

      <section class="mt-6 rounded-[2rem] border border-stone-200 bg-stone-100 px-6 py-10 text-stone-900 shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)] md:px-10">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Custom Delivery</p>
        <h2 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">
          Need an in-house version shaped around your team?
        </h2>
        <p class="mt-5 max-w-3xl text-base leading-8 text-stone-600">
          Use this program as a reference point for a private cohort, tailored scope, or a workshop designed around a current delivery challenge.
        </p>
        {program.registrationNote && <p class="mt-4 max-w-3xl text-sm leading-7 text-stone-500">{program.registrationNote}</p>}
        <div class="mt-8 flex flex-wrap gap-3">
          {program.registrationEnabled ? (
            <a class="btn-primary !rounded-md !px-7 !py-3.5" href={`/programs/register/${program.slug}`}>Register</a>
          ) : (
            <a class="btn-primary !rounded-md !px-7 !py-3.5" href="/contact">Contact Us</a>
          )}
          <a class="btn-secondary !rounded-md !border-stone-300 !px-7 !py-3.5 !text-stone-800" href={backHref}>
            {backLabel}
          </a>
        </div>
      </section>
    </article>
  ) : (
    <section class="mx-auto max-w-5xl px-4 py-14 md:px-6 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">404</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-5xl">Program not found</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-600">The requested training program is not available.</p>
    </section>
  )}
</MainLayout>
