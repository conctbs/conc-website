---
import PageCover from "./PageCover.astro";

const { sections = [], fallbackEyebrow = "CONC", fallbackTitle = "Page" } = Astro.props;

const heroSection = sections.find((section) => section.type === "hero");
const richTextSections = sections.filter((section) => section.type === "rich-text");
const faqSection = sections.find((section) => section.type === "faq");
const ctaSection = sections.find((section) => section.type === "call-to-action");

const eyebrow = heroSection?.eyebrow ?? fallbackEyebrow;
const title = heroSection?.title ?? fallbackTitle;
const description = heroSection?.description ?? null;
---

<section class="border-b border-stone-200 bg-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
    <div class="max-w-4xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">{eyebrow}</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">{title}</h1>
      {description && <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">{description}</p>}

      {(heroSection?.primaryButtonText || heroSection?.secondaryButtonText) && (
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          {heroSection?.primaryButtonText && heroSection?.primaryButtonUrl && (
            <a class="btn-primary !rounded-md !px-7 !py-3.5" href={heroSection.primaryButtonUrl}>
              {heroSection.primaryButtonText}
            </a>
          )}
          {heroSection?.secondaryButtonText && heroSection?.secondaryButtonUrl && (
            <a class="btn-secondary !rounded-md !border-stone-300 !px-7 !py-3.5 !text-stone-800" href={heroSection.secondaryButtonUrl}>
              {heroSection.secondaryButtonText}
            </a>
          )}
        </div>
      )}
    </div>

    <PageCover eyebrow={eyebrow} title={title} />
  </div>
</section>

{richTextSections.length > 0 && (
  <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
    <div class="grid gap-6">
      {richTextSections.map((section) => (
        <article class="rounded-[1.75rem] border border-stone-200 bg-white p-7 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)]">
          {(section.eyebrow || section.title) && (
            <div>
              {section.eyebrow && <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">{section.eyebrow}</p>}
              {section.title && <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">{section.title}</h2>}
              {section.description && <p class="mt-4 max-w-3xl text-base leading-8 text-stone-600">{section.description}</p>}
            </div>
          )}
          {section.body && <div class="prose prose-stone mt-6 max-w-none prose-headings:text-stone-900 prose-p:text-stone-700" set:html={section.body} />}
        </article>
      ))}
    </div>
  </section>
)}

{faqSection && faqSection.items.length > 0 && (
  <section class="border-y border-stone-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-14 md:px-6">
      <div class="max-w-3xl">
        {faqSection.eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">{faqSection.eyebrow}</p>}
        {faqSection.title && <h2 class="mt-3 text-3xl font-semibold leading-tight text-stone-900 md:text-4xl">{faqSection.title}</h2>}
        {faqSection.description && <p class="mt-4 text-base leading-8 text-stone-600">{faqSection.description}</p>}
      </div>

      <div class="mt-8 grid gap-4">
        {faqSection.items.map((item) => (
          <details class="rounded-[1.5rem] border border-stone-200 bg-stone-50 px-5 py-4">
            <summary class="cursor-pointer list-none text-lg font-semibold text-stone-900">{item.question}</summary>
            <p class="mt-4 text-base leading-8 text-stone-600">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

{ctaSection && (
  <section class="mx-auto max-w-7xl px-4 py-14 md:px-6 md:pb-20">
    <div class="rounded-[2rem] border border-stone-200 bg-stone-100 px-6 py-8 md:px-8 md:py-10">
      {ctaSection.eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">{ctaSection.eyebrow}</p>}
      {ctaSection.title && <h2 class="mt-3 text-3xl font-semibold leading-tight text-stone-900 md:text-4xl">{ctaSection.title}</h2>}
      {ctaSection.description && <p class="mt-4 max-w-3xl text-base leading-8 text-stone-600">{ctaSection.description}</p>}
      {ctaSection.buttonText && ctaSection.buttonUrl && (
        <div class="mt-6">
          <a class="btn-primary !rounded-md !px-7 !py-3.5" href={ctaSection.buttonUrl}>{ctaSection.buttonText}</a>
        </div>
      )}
    </div>
  </section>
)}
