---
import '../assets/styles/tailwind.css';

import ConsentModeHead from '~/components/analytics/ConsentModeHead.astro';
import CookieConsentBanner from '~/components/analytics/CookieConsentBanner.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import Announcement from '~/components/widgets/Announcement.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';
import { I18N, SITE } from '~/theme-config';
import { getCanonical } from '~/utils/permalinks';

const { title, seo = null, siteSetting = null } = Astro.props;
const pageTitle = title ?? siteSetting?.siteName ?? SITE.name;
const pageDescription = seo?.metaDescription ?? siteSetting?.siteDescription ?? null;
const canonical = seo?.canonicalUrl ?? String(getCanonical(String(Astro.url.pathname)));
const gtmId = import.meta.env.PUBLIC_GTM_ID?.trim() ?? '';
---

<!doctype html>
<html lang={I18N.language} dir={I18N.textDirection} class="2xl:text-[20px]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {pageDescription && <meta name="description" content={pageDescription} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {seo?.noIndex && <meta name="robots" content="noindex,nofollow" />}
    <Favicons />
    <CustomStyles />
    <ConsentModeHead />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${encodeURIComponent(gtmId)}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          ></iframe>
        </noscript>
      )
    }
    <Announcement />
    <Header {...headerData} isSticky />
    <main>
      <slot />
    </main>
    <Footer {...footerData} />
    <CookieConsentBanner />
    <BasicScripts />
  </body>
</html>
