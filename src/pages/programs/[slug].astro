---
import MainLayout from '../../layouts/MainLayout.astro';
import PageCover from '../../components/PageCover.astro';
import { getProgramBySlug, getProgramSlugs, getSiteSetting } from '../../lib/api';

export async function getStaticPaths() {
  const slugs = await getProgramSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug = '' } = Astro.params;
const [siteSetting, program] = await Promise.all([getSiteSetting(), getProgramBySlug(slug)]);
const backHref = program?.isForumEvent ? '/life-long-learning/conc-thammasat-forum' : '/programs';
const backLabel = program?.isForumEvent ? 'Back to CONC Thammasat Forum' : 'Back to programs';
const testimonialCarouselId = program ? `testimonial-carousel-${program.slug}` : '';
const agendaHeading = program?.isForumEvent ? 'Forum flow' : 'Learning modules';

if (!program) {
  Astro.response.status = 404;
}
---

<MainLayout title={program?.seo?.metaTitle ?? program?.title ?? 'Program'} seo={program?.seo} siteSetting={siteSetting}>
  {program ? (
    <article class="mx-auto max-w-7xl px-4 py-14 md:px-6 md:py-20">
      <a class="inline-flex text-sm font-semibold text-red-700 transition hover:text-red-800" href={backHref}>{backLabel}</a>

      <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1.08fr)_minmax(20rem,0.92fr)]">
        <div>
          <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">
            <span class="rounded-full bg-red-700 px-3 py-1 text-white">{program.forumSeriesLabel ?? program.category ?? 'Program'}</span>
            {program.format && <span>{program.format}</span>}
            {program.dateLabel && <span>{program.dateLabel}</span>}
          </div>
          <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight text-stone-900 md:text-5xl lg:text-6xl">
            {program.title}
          </h1>
          {program.tagline && <p class="mt-4 max-w-3xl text-xl leading-8 text-red-700">{program.tagline}</p>}
          <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-600">{program.summary}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            {program.registrationEnabled ? (
              <a class="btn-primary !rounded-md !px-7 !py-3.5" href={`/programs/register/${program.slug}`}>Register</a>
            ) : (
              <span class="rounded-full border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold uppercase tracking-[0.14em] text-red-700">
                Registration closed
              </span>
            )}
            <a class="btn-secondary !rounded-md !border-stone-300 !px-7 !py-3.5 !text-stone-800" href="/contact">
              Contact Us
            </a>
          </div>
        </div>

        <div class="grid gap-6">
          {program.coverImage?.url ? (
            <figure class="overflow-hidden rounded-[1.75rem] border border-stone-200 bg-white shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)]">
              <img
                class="h-full w-full object-cover"
                src={program.coverImage.url}
                alt={program.coverImage.alternativeText ?? program.title}
                loading="eager"
              />
            </figure>
          ) : (
            <PageCover eyebrow={program.category ?? 'Program'} title={program.title} theme="programs" />
          )}
          <aside class="rounded-[1.75rem] border border-stone-200 bg-stone-100 p-6 text-stone-900 shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)]">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-500">Program overview</p>
            <div class="mt-6 grid gap-4">
              <div class="rounded-2xl border border-stone-200 bg-white p-4">
                <p class="text-sm text-stone-500">Audience</p>
                <p class="mt-2 text-base font-medium text-stone-900">{program.audience}</p>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl border border-stone-200 bg-white p-4">
                  <p class="text-sm text-stone-500">Starts</p>
                  <p class="mt-2 text-base font-medium text-stone-900">{program.startsAt ?? 'TBC'}</p>
                </div>
                <div class="rounded-2xl border border-stone-200 bg-white p-4">
                  <p class="text-sm text-stone-500">Location</p>
                  <p class="mt-2 text-base font-medium text-stone-900">{program.location}</p>
                </div>
                <div class="rounded-2xl border border-stone-200 bg-white p-4">
                  <p class="text-sm text-stone-500">Fee</p>
                  <p class="mt-2 text-base font-medium text-stone-900">{program.fee}</p>
                </div>
                <div class="rounded-2xl border border-stone-200 bg-white p-4">
                  <p class="text-sm text-stone-500">Duration</p>
                  <p class="mt-2 text-base font-medium text-stone-900">{program.duration}</p>
                </div>
              </div>
              <div class="rounded-2xl border border-stone-200 bg-white p-4">
                <p class="text-sm text-stone-500">Seats</p>
                <p class="mt-2 text-base font-medium text-stone-900">{program.seats ? `${program.seats} seats` : 'TBC'}</p>
              </div>
              {!program.registrationEnabled && (
                <div class="rounded-2xl border border-red-200 bg-red-50 p-4">
                  <p class="text-sm text-red-600">Registration</p>
                  <p class="mt-2 text-base font-medium text-red-700">Closed</p>
                </div>
              )}
            </div>
          </aside>
        </div>
      </section>

      <section class="mt-10 grid gap-6 lg:grid-cols-2">
        <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Program Overview</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">What participants will work through</h2>
          <div class="mt-5 space-y-4 text-base leading-8 text-stone-600">
            {program.overview.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>
        <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Learning Outcomes</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Expected takeaways</h2>
          <ul class="mt-5 space-y-3 pl-5 text-base leading-8 text-stone-600 marker:text-red-700">
            {program.outcomes.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </section>

      {program.testimonials.length > 0 && (
        <section class="mt-6 overflow-hidden rounded-[2rem] border border-stone-200 bg-[linear-gradient(135deg,#fff7ed_0%,#ffffff_42%,#f5f5f4_100%)] p-8 shadow-[0_24px_70px_-36px_rgba(41,37,36,0.4)] md:p-10">
          <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
            <div class="relative max-w-3xl">
              <div class="pointer-events-none absolute -left-4 -top-6 text-7xl leading-none text-red-100 md:text-8xl">“</div>
              <p class="relative text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Testimonials</p>
              <h2 class="relative mt-4 text-3xl font-semibold leading-tight text-stone-900 md:text-4xl">What participants took back to work</h2>
              <p class="mt-4 text-base leading-8 text-stone-600">
                Participant feedback from this program and related cohorts.
              </p>
            </div>
            {program.testimonials.length > 1 && (
              <div class="flex items-center gap-3">
                <button
                  type="button"
                  class="testimonial-nav-button"
                  data-carousel-prev={testimonialCarouselId}
                  aria-label="Show previous testimonial"
                >
                  Previous
                </button>
                <button
                  type="button"
                  class="testimonial-nav-button"
                  data-carousel-next={testimonialCarouselId}
                  aria-label="Show next testimonial"
                >
                  Next
                </button>
              </div>
            )}
          </div>
          <div
            class="mt-8"
            data-testimonial-carousel={testimonialCarouselId}
            data-carousel-count={program.testimonials.length}
          >
            <div class="overflow-hidden">
              <div class="flex transition-transform duration-500 ease-out" data-carousel-track>
                {program.testimonials.map((testimonial) => (
                  <div class="w-full shrink-0" data-carousel-slide>
                    <article class="group relative overflow-hidden rounded-[1.6rem] border border-stone-200/80 bg-white/90 p-6 shadow-[0_18px_48px_-32px_rgba(120,53,15,0.45)] backdrop-blur md:p-7">
                      <div class="absolute right-5 top-4 text-5xl leading-none text-red-100 transition group-hover:text-red-200">”</div>
                      <div class="relative flex h-full flex-col">
                        <blockquote class="max-w-[42rem] text-lg leading-8 text-stone-800 md:text-[1.15rem]">
                          {testimonial.quote}
                        </blockquote>
                        <div class="mt-6 flex items-center gap-4 border-t border-stone-200 pt-5">
                          {testimonial.authorAvatar?.url ? (
                            <img
                              class="h-16 w-16 rounded-full border border-stone-200 object-cover shadow-[0_10px_25px_-18px_rgba(41,37,36,0.9)]"
                              src={testimonial.authorAvatar.url}
                              alt={testimonial.authorAvatar.alternativeText ?? testimonial.authorName ?? program.title}
                              loading="lazy"
                            />
                          ) : (
                            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-red-100 text-sm font-semibold uppercase tracking-[0.12em] text-red-700">
                              {(testimonial.authorName ?? '?').slice(0, 2)}
                            </div>
                          )}
                          <div class="min-w-0">
                            <p class="text-base font-semibold text-stone-900">{testimonial.authorName}</p>
                            <p class="mt-1 text-sm leading-6 text-stone-500">
                              {[testimonial.authorRole, testimonial.authorCompany].filter(Boolean).join(' | ')}
                            </p>
                          </div>
                        </div>
                      </div>
                    </article>
                  </div>
                ))}
              </div>
            </div>
            {program.testimonials.length > 1 && (
              <div class="mt-5 flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                  {program.testimonials.map((_, index) => (
                    <button
                      type="button"
                      class:list={['testimonial-dot', index === 0 && 'is-active']}
                      data-carousel-dot={index}
                      data-carousel-target={testimonialCarouselId}
                      aria-label={`Show testimonial ${index + 1}`}
                    />
                  ))}
                </div>
                <p class="text-sm text-stone-500">
                  <span data-carousel-current>1</span> / {program.testimonials.length}
                </p>
              </div>
            )}
          </div>
        </section>
      )}

      {program.speakers.length > 0 && (
        <section class="mt-6">
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Speakers</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Session contributors</h2>
            <div class="mt-6 grid gap-4 lg:grid-cols-2">
              {program.speakers.map((speaker) => (
                <div class="rounded-2xl border border-stone-200 bg-stone-50 p-5">
                  <p class="text-lg font-semibold text-stone-900">{speaker.name}</p>
                  <p class="mt-1 text-sm font-medium text-red-700">{[speaker.role, speaker.organization].filter(Boolean).join(' | ')}</p>
                  {speaker.bio && <p class="mt-3 text-sm leading-7 text-stone-600">{speaker.bio}</p>}
                </div>
              ))}
            </div>
          </article>
        </section>
      )}

      {program.agendaItems.length > 0 && (
        <section class="mt-6">
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)] md:p-7">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Agenda</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">{agendaHeading}</h2>
            <div class:list={[
              'mt-6 grid gap-3',
              program.agendaItems.length >= 6 ? 'lg:grid-cols-2 xl:grid-cols-3' : 'xl:grid-cols-2',
            ]}>
              {program.agendaItems.map((item) => (
                <div class="rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3.5">
                  <div class="flex flex-wrap items-start justify-between gap-2">
                    <div class="min-w-0 flex-1">
                      {item.timeLabel && <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-red-700">{item.timeLabel}</p>}
                      <p class:list={['font-semibold text-stone-900', item.timeLabel ? 'mt-1 text-base leading-6' : 'text-base leading-6']}>
                        {item.title}
                      </p>
                      {item.speakerName && <p class="mt-1 text-xs leading-5 text-stone-500">{item.speakerName}</p>}
                    </div>
                    {item.description && !item.speakerName && (
                      <span class="shrink-0 rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-stone-500">
                        {item.description}
                      </span>
                    )}
                  </div>
                  {item.description && item.speakerName && <p class="mt-2 text-xs leading-6 text-stone-600">{item.description}</p>}
                </div>
              ))}
            </div>
          </article>
        </section>
      )}

      {program.gallery.length > 0 && (
        <section class="mt-6 rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Gallery</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Event visuals</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {program.gallery.map((image) => (
              image?.url ? <img class="h-64 w-full rounded-2xl object-cover" src={image.url} alt={image.alternativeText ?? program.title} /> : null
            ))}
          </div>
        </section>
      )}

      <section class="mt-6 rounded-[2rem] border border-stone-200 bg-stone-100 px-6 py-10 text-stone-900 shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)] md:px-10">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Custom Delivery</p>
        <h2 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">
          Need an in-house version shaped around your team?
        </h2>
        <p class="mt-5 max-w-3xl text-base leading-8 text-stone-600">
          Use this program as a reference point for a private cohort, tailored scope, or a workshop designed around a current delivery challenge.
        </p>
        {program.registrationNote && <p class="mt-4 max-w-3xl text-sm leading-7 text-stone-500">{program.registrationNote}</p>}
        <div class="mt-8 flex flex-wrap gap-3">
          {program.registrationEnabled ? (
            <a class="btn-primary !rounded-md !px-7 !py-3.5" href={`/programs/register/${program.slug}`}>Register</a>
          ) : (
            <a class="btn-primary !rounded-md !px-7 !py-3.5" href="/contact">Contact Us</a>
          )}
          <a class="btn-secondary !rounded-md !border-stone-300 !px-7 !py-3.5 !text-stone-800" href={backHref}>
            {backLabel}
          </a>
        </div>
      </section>
    </article>
  ) : (
    <section class="mx-auto max-w-5xl px-4 py-14 md:px-6 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">404</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-5xl">Program not found</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-600">The requested training program is not available.</p>
    </section>
  )}
</MainLayout>

<script is:inline>
  {`
    (() => {
      const carousels = Array.from(document.querySelectorAll('[data-testimonial-carousel]'));
      for (const carousel of carousels) {
        const id = carousel.getAttribute('data-testimonial-carousel');
        const track = carousel.querySelector('[data-carousel-track]');
        const dots = Array.from(document.querySelectorAll('[data-carousel-target="' + id + '"]'));
        const prevButton = document.querySelector('[data-carousel-prev="' + id + '"]');
        const nextButton = document.querySelector('[data-carousel-next="' + id + '"]');
        const currentLabel = carousel.querySelector('[data-carousel-current]');
        const count = Number(carousel.getAttribute('data-carousel-count') || '0');
        let index = 0;

        if (!id || !track || count <= 1) continue;

        const update = () => {
          track.style.transform = 'translate3d(-' + index * 100 + '%, 0, 0)';
          dots.forEach((dot, dotIndex) => {
            dot.classList.toggle('is-active', dotIndex === index);
          });
          if (currentLabel) currentLabel.textContent = String(index + 1);
        };

        prevButton?.addEventListener('click', () => {
          index = index === 0 ? count - 1 : index - 1;
          update();
        });

        nextButton?.addEventListener('click', () => {
          index = index === count - 1 ? 0 : index + 1;
          update();
        });

        dots.forEach((dot, dotIndex) => {
          dot.addEventListener('click', () => {
            index = dotIndex;
            update();
          });
        });

        update();
      }
    })();
  `}
</script>

<style>
  .testimonial-nav-button {
    border: 1px solid rgb(214 211 209 / 1);
    background: rgba(255, 255, 255, 0.9);
    color: rgb(28 25 23 / 1);
    border-radius: 999px;
    padding: 0.8rem 1rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .testimonial-nav-button:hover {
    border-color: rgb(185 28 28 / 1);
    color: rgb(185 28 28 / 1);
    transform: translateY(-1px);
  }

  .testimonial-dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    border: 0;
    background: rgb(229 231 235 / 1);
    transition: transform 160ms ease, background-color 160ms ease;
  }

  .testimonial-dot.is-active {
    background: rgb(185 28 28 / 1);
    transform: scale(1.15);
  }
</style>
