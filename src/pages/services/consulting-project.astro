---
import InfoPage from "../../components/InfoPage.astro";
import SectionRenderer from "../../components/SectionRenderer.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getPageBySlug, getSiteSetting } from "../../lib/api";

const [page, siteSetting] = await Promise.all([getPageBySlug("consulting-project"), getSiteSetting()]);
const title = page?.seo?.metaTitle ?? page?.title ?? "Consulting Project | CONC";
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  {page ? (
    <SectionRenderer sections={page.sections} />
  ) : (
    <InfoPage
      eyebrow="Consulting Service"
      title="Consulting Project"
      intro="Selected consulting projects can be curated here from the backend to show delivery scope, client context, and practical outcomes."
      sections={[
        {
          title: "Case References",
          body: "This route is designed to highlight consulting work that helps visitors understand the range and depth of advisory engagements managed by CONC.",
        },
        {
          title: "Backend-Managed Listings",
          body: "Project entries can be maintained in Strapi so editors can update titles, summaries, client references, and featured order without frontend code changes.",
        },
        {
          title: "Conversion Path",
          body: "The page can connect past work to the next inquiry step, making it easier for prospective clients to move from browsing examples into a real conversation.",
        },
      ]}
    />
  )}
</MainLayout>
