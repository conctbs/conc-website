---
import MainLayout from '../layouts/MainLayout.astro';
import PageCover from '../components/PageCover.astro';
import { getPageBySlug, getServices, getSiteSetting } from '../lib/api';

const [page, siteSetting, services] = await Promise.all([getPageBySlug('services'), getSiteSetting(), getServices()]);
const title = page?.seo?.metaTitle ?? page?.title ?? siteSetting?.siteName ?? 'Services';
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  <section class="border-b border-gray-200 bg-white">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
      <div class="max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Consulting Service</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">
          {page?.sections?.find((section) => section.type === 'hero')?.title ?? 'A focused set of service lines shaped for institutional positioning'}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
          {page?.sections?.find((section) => section.type === 'hero')?.description ??
            'These service entries connect the consulting offering to project work, frontend routes, and reusable content architecture.'}
        </p>
      </div>
      <PageCover eyebrow="Services" title="Consulting offers, delivery scope, and capability paths" theme="services" />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {services.map((service) => (
        <article class="group rounded-[1.75rem] border border-stone-200 bg-white p-7 transition hover:-translate-y-1 hover:border-red-700">
          <div class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Service Area</div>
          <h2 class="mt-4 text-2xl font-semibold text-stone-900">{service.name}</h2>
          <p class="mt-4 text-sm leading-7 text-stone-600">{service.description}</p>
          <a class="mt-6 inline-flex items-center text-sm font-semibold text-red-700" href={`/services/${service.slug}`}>
            Read more
            <span class="ml-2">→</span>
          </a>
        </article>
      ))}
    </div>
  </section>
</MainLayout>
