<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 4px 20px;
    backdrop-filter: blur(18px);
    background: rgba(185, 28, 28, 0.96);
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    flex-shrink: 0;
  }

  .brand img {
    display: block;
    width: auto;
    width: 92px;
    height: 92px;
    object-fit: contain;
  }

  .brand-text {
    display: flex;
    align-items: center;
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
    max-width: 320px;
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .menu-toggle {
    display: none;
    width: 48px;
    height: 48px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
  }

  .menu-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: 999px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .menu-toggle .bars {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-links {
    display: flex;
    gap: 20px;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-end;
    margin-left: auto;
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
  }

  .nav-item-shell {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .nav-parent-link {
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .nav-trigger,
  nav a {
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .nav-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.8rem;
    height: 1.8rem;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    cursor: pointer;
    font: inherit;
  }

  .nav-trigger::after {
    content: "";
    width: 0.55rem;
    height: 0.55rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
    transition: transform 0.2s ease;
  }

  nav a:hover {
    color: rgba(255, 255, 255, 0.82);
  }

  .submenu {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    display: grid;
    min-width: 220px;
    padding: 0.8rem;
    border: 1px solid rgba(15, 15, 16, 0.08);
    border-radius: 18px;
    background: rgba(243, 244, 246, 0.98);
    box-shadow: 0 20px 40px rgba(15, 15, 16, 0.12);
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .submenu a {
    padding: 0.7rem 0.85rem;
    border-radius: 12px;
    font-size: 0.92rem;
    color: var(--text);
  }

  .submenu a:hover {
    background: rgba(185, 28, 28, 0.08);
    color: var(--accent-2);
  }

  .nav-parent-link:hover,
  .nav-trigger:hover,
  .nav-trigger:focus-visible {
    color: rgba(255, 255, 255, 0.82);
  }

  .nav-item.has-submenu:hover .submenu,
  .nav-item.has-submenu:focus-within .submenu,
  .nav-item.has-submenu[data-submenu-open="true"] .submenu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav-item.has-submenu[data-submenu-open="true"] .nav-trigger::after,
  .nav-item.has-submenu:hover .nav-trigger::after,
  .nav-item.has-submenu:focus-within .nav-trigger::after {
    transform: rotate(225deg) translateY(-1px);
  }

  @media (max-width: 900px) {
    nav {
      align-items: stretch;
      flex-direction: column;
      padding: 4px 12px;
    }

    .nav-shell {
      width: 100%;
    }

    .brand img {
      width: 80px;
      height: 80px;
    }

    .brand-text {
      font-size: 0.8rem;
      max-width: 220px;
    }

    .menu-toggle {
      display: inline-flex;
      flex-shrink: 0;
    }

    .nav-links {
      display: none;
      flex-direction: column;
      gap: 14px;
      flex-wrap: nowrap;
      align-items: stretch;
      padding-top: 8px;
      border-top: 1px solid rgba(255, 255, 255, 0.18);
      margin-left: 0;
    }

    .nav-item {
      flex-direction: column;
      align-items: stretch;
    }

    .nav-item-shell,
    .nav-parent-link,
    .nav-links > a {
      display: flex;
      align-items: center;
    }

    .nav-item-shell,
    .nav-links > a {
      justify-content: space-between;
      padding: 0.2rem 0;
    }

    .nav-parent-link {
      flex: 1;
      padding: 0.2rem 0;
    }

    .nav-trigger {
      width: 2rem;
      height: 2rem;
      flex-shrink: 0;
    }

    .submenu {
      position: static;
      min-width: 0;
      margin-top: 0.5rem;
      padding: 0 0 0 1rem;
      border: 0;
      border-left: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      opacity: 1;
      pointer-events: auto;
      transform: none;
      display: none;
    }

    .submenu a {
      padding: 0.55rem 0;
    }

    nav[data-open="true"] .nav-links {
      display: flex;
    }

    .nav-item.has-submenu[data-submenu-open="true"] .submenu {
      display: grid;
    }

    nav[data-open="true"] .menu-toggle span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    nav[data-open="true"] .menu-toggle span:nth-child(2) {
      opacity: 0;
    }

    nav[data-open="true"] .menu-toggle span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }
  }
</style>

<nav data-open="false" id="site-nav">
  <div class="nav-shell">
    <a class="brand" href="/" aria-label="CONC home">
      <img src="/conc-logo.svg" alt="CONC Thammasat Business School logo" />
      <span class="brand-text">Thammasat Consulting Networking and Coaching Center</span>
    </a>

    <button class="menu-toggle" id="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle navigation">
      <span class="bars">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <div class="nav-links" id="primary-nav">
    <a href="/">Home</a>
    <div class="nav-item has-submenu" data-submenu-open="false">
      <div class="nav-item-shell">
        <a class="nav-parent-link" href="/about">About Us</a>
        <button
          class="nav-trigger"
          type="button"
          aria-expanded="false"
          aria-controls="about-submenu"
          aria-label="Toggle About Us menu"
        >
          <span class="sr-only">Open About Us submenu</span>
        </button>
      </div>
      <div class="submenu" id="about-submenu">
        <a href="/about">Overview</a>
        <a href="/about/philosophy">Philosophy</a>
        <a href="/about/executive">Executive</a>
        <a href="/about/facilities">Facilities</a>
        <a href="/sitemap">Sitemap</a>
        <a href="/privacy-policy">Privacy Policy</a>
      </div>
    </div>
    <a href="/services">Services</a>
    <a href="/programs">Programs</a>
    <a href="/projects">Projects</a>
    <a href="/news">News</a>
    <a href="/contact">Contact</a>
  </div>
</nav>

<script is:inline>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('menu-toggle');
  const links = document.querySelectorAll('#primary-nav a');
  const submenuItem = document.querySelector('.nav-item.has-submenu');
  const submenuTrigger = submenuItem?.querySelector('.nav-trigger');

  function setOpen(nextOpen) {
    if (!nav || !toggle) return;
    nav.dataset.open = nextOpen ? 'true' : 'false';
    toggle.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
  }

  function setSubmenuOpen(nextOpen) {
    if (!submenuItem || !submenuTrigger) return;
    submenuItem.dataset.submenuOpen = nextOpen ? 'true' : 'false';
    submenuTrigger.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.dataset.open === 'true';
    setOpen(!isOpen);
  });

  submenuTrigger?.addEventListener('click', () => {
    const isOpen = submenuItem?.dataset.submenuOpen === 'true';
    setSubmenuOpen(!isOpen);
  });

  links.forEach((link) => {
    link.addEventListener('click', () => {
      setSubmenuOpen(false);
      if (window.innerWidth <= 900) {
        setOpen(false);
      }
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 900) {
      setOpen(false);
      setSubmenuOpen(false);
    }
  });

  document.addEventListener('click', (event) => {
    if (!submenuItem) return;
    if (!submenuItem.contains(event.target)) {
      setSubmenuOpen(false);
    }
  });
</script>
