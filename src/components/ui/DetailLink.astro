---
import Button from './Button.astro';

interface Props {
  href: string;
  label?: string;
  compact?: boolean;
  class?: string;
}

const { href, label = 'View details', compact = false, class: className = '' } = Astro.props;
---

<Button
  variant="secondary"
  href={href}
  text={label}
  class:list={[
    'detail-link !inline-flex !items-center !justify-center !rounded-md !border-stone-300 !font-semibold !text-stone-800 no-underline transition hover:!border-red-700 hover:!text-red-700',
    compact ? '!px-5 !py-2.5 !text-sm' : '!px-6 !py-3',
    className,
  ]}
/>
