---
interface SectionItem {
  title: string;
  body: string;
}

interface QuickLinkItem {
  text: string;
  href: string;
}

const {
  eyebrow,
  title,
  intro,
  sections = [],
  lastUpdated = null,
  quickLinks = [],
} = Astro.props as {
  eyebrow: string;
  title: string;
  intro: string;
  sections?: SectionItem[];
  lastUpdated?: string | null;
  quickLinks?: QuickLinkItem[];
};
---

<section class="border-b border-stone-200 bg-white">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-6 md:py-20">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)] lg:items-end">
      <div>
        <p
          class="inline-flex rounded-full border border-red-700/20 bg-red-50 px-4 py-1 text-sm font-semibold uppercase tracking-[0.18em] text-red-700"
        >
          {eyebrow}
        </p>
        <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight text-stone-900 md:text-5xl lg:text-6xl">
          {title}
        </h1>
        <p class="mt-6 max-w-3xl text-base leading-8 text-stone-600 md:text-lg">
          {intro}
        </p>
      </div>

      <aside class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-6 shadow-[0_20px_60px_-32px_rgba(41,37,36,0.38)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Information brief</p>
        <div class="mt-5 space-y-4">
          <div>
            <p class="text-sm text-stone-500">Content sections</p>
            <p class="mt-1 text-2xl font-semibold text-stone-900">{sections.length}</p>
          </div>
          {lastUpdated && (
            <div class="border-t border-stone-200 pt-4">
              <p class="text-sm text-stone-500">Last updated</p>
              <p class="mt-1 text-base font-medium text-stone-900">{lastUpdated}</p>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-16 md:px-6">
  <div class="grid gap-6 lg:grid-cols-3">
    {sections.map((section, index) => (
      <article
        class:list={[
          'rounded-[1.75rem] border border-stone-200 bg-white p-7 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]',
          index === 0 && sections.length === 1 && 'lg:col-span-2',
        ]}
      >
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">
          Section {String(index + 1).padStart(2, '0')}
        </p>
        <h2 class="mt-4 text-2xl font-semibold leading-tight text-stone-900">{section.title}</h2>
        <p class="mt-4 text-sm leading-7 text-stone-600 md:text-base">
          {section.body}
        </p>
      </article>
    ))}
  </div>

  {quickLinks.length > 0 && (
    <div class="mt-12">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Quick links</p>
        <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Browse related sections</h2>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {quickLinks.map((link) => (
          <a
            class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700"
            href={link.href}
          >
            {link.text}
          </a>
        ))}
      </div>
    </div>
  )}
</section>
