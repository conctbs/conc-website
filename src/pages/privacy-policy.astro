---
import PageCover from "../components/PageCover.astro";
import StructuredPageContent from "../components/StructuredPageContent.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { getPageBySlug, getSiteSetting } from "../lib/api";

const [page, siteSetting] = await Promise.all([getPageBySlug("privacy-policy"), getSiteSetting()]);
const title = page?.seo?.metaTitle ?? page?.title ?? "Privacy Policy | CONC";
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  {page ? (
    <StructuredPageContent sections={page.sections} fallbackEyebrow="About Us" fallbackTitle="Privacy Policy" />
  ) : (
    <>
      <section class="border-b border-stone-200 bg-white">
        <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
          <div class="max-w-4xl">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">About Us</p>
            <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">Privacy Policy</h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
              How CONC collects, uses, stores, and protects personal information submitted through this website.
            </p>
          </div>
          <PageCover eyebrow="Privacy" title="Personal data handling, operational use, and access controls" />
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.95fr)]">
          <div class="grid gap-6">
            <article class="rounded-[1.75rem] border border-stone-200 bg-white p-7">
              <h2 class="text-2xl font-semibold text-stone-900">Information We Collect</h2>
              <p class="mt-4 text-base leading-8 text-stone-600">This covers personal and operational information submitted through forms, registrations, inquiries, and related service workflows.</p>
            </article>
            <article class="rounded-[1.75rem] border border-stone-200 bg-white p-7">
              <h2 class="text-2xl font-semibold text-stone-900">How Information Is Used</h2>
              <p class="mt-4 text-base leading-8 text-stone-600">Collected information is used to respond to inquiries, manage registrations, deliver services, and maintain necessary operational records.</p>
            </article>
            <article class="rounded-[1.75rem] border border-stone-200 bg-white p-7">
              <h2 class="text-2xl font-semibold text-stone-900">Retention and Access</h2>
              <p class="mt-4 text-base leading-8 text-stone-600">Information is retained only as needed for legitimate operational or compliance reasons, with access limited to authorized personnel.</p>
            </article>
          </div>
          <aside class="grid gap-4 rounded-[1.75rem] border border-stone-200 bg-stone-50 p-6">
            <div>
              <p class="text-sm text-stone-500">Last updated</p>
              <p class="mt-1 text-xl font-semibold text-stone-900">March 24, 2026</p>
            </div>
            <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 font-semibold text-stone-900 transition hover:border-red-700 hover:text-red-700" href="/about">About CONC</a>
            <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 font-semibold text-stone-900 transition hover:border-red-700 hover:text-red-700" href="/contact">Contact Us</a>
            <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 font-semibold text-stone-900 transition hover:border-red-700 hover:text-red-700" href="/sitemap">Sitemap</a>
          </aside>
        </div>
      </section>
    </>
  )}
</MainLayout>
