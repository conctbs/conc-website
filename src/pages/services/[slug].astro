---
import MainLayout from '../../layouts/MainLayout.astro';
import { getServiceBySlug, getServiceSlugs, getSiteSetting } from '../../lib/api';

export async function getStaticPaths() {
  const slugs = await getServiceSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug = '' } = Astro.params;
const [service, siteSetting] = await Promise.all([getServiceBySlug(slug), getSiteSetting()]);

if (!service) {
  Astro.response.status = 404;
}

const pageTitle = service?.seo?.metaTitle ?? service?.name ?? siteSetting?.siteName ?? 'Service';
const pageDescription = service?.seo?.metaDescription ?? service?.description ?? siteSetting?.siteDescription ?? null;
---

<MainLayout title={pageTitle} seo={service?.seo} siteSetting={siteSetting}>
  {service ? (
    <article class="detail-page">
      <a class="back-link" href="/services">Back to services</a>
      <header class="detail-hero">
        <div class="detail-copy">
          <div class="eyebrow">Service Detail</div>
          <h1>{service.name}</h1>
          {pageDescription && <p class="lead">{pageDescription}</p>}
        </div>
        <div class="detail-panel">
          {service.icon?.url ? (
            <img src={service.icon.url} alt={service.icon.alternativeText ?? service.name} loading="eager" />
          ) : (
            <div class="placeholder">
              <div class="placeholder-kicker">Service</div>
              <strong>{service.name}</strong>
              <p>Media can be connected from Strapi later without changing this layout.</p>
            </div>
          )}
        </div>
      </header>
      <section class="content-card prose-block">
        <div class="section-head">
          <div class="eyebrow">Overview</div>
          <h2>What this service covers</h2>
        </div>
        <p>{service.description ?? 'No service description is available yet.'}</p>
      </section>
      <section class="action-card">
        <div class="eyebrow">Next Step</div>
        <h2>Need this capability in your stack?</h2>
        <p>Use the contact route to discuss delivery scope, CMS structure, and implementation priorities.</p>
        <div class="action-row">
          <a class="button primary" href="/contact">Contact Us</a>
          <a class="button secondary" href="/projects">See Related Projects</a>
        </div>
      </section>
    </article>
  ) : (
    <section class="missing-state">
      <div class="eyebrow">404</div>
      <h1>Service not found</h1>
      <p>The requested service slug is not available from Strapi.</p>
      <a class="back-link" href="/services">Back to services</a>
    </section>
  )}
</MainLayout>

<style>
  .detail-page, .missing-state { padding: 4rem 0 5rem; }
  .back-link { display: inline-flex; margin-bottom: 1.5rem; color: var(--accent); text-decoration: none; font-weight: 700; }
  .detail-hero { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr); gap: 2rem; align-items: start; }
  .detail-copy h1, .missing-state h1 { margin: 0.35rem 0 1rem; font-size: clamp(3rem, 6vw, 4.8rem); line-height: 0.95; }
  .eyebrow { color: var(--muted); text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.72rem; }
  .lead, .missing-state p { max-width: 40rem; color: var(--muted); font-size: 1.1rem; line-height: 1.8; }
  .detail-panel, .content-card { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-card); box-shadow: var(--shadow-soft); }
  .action-card { margin-top: 2rem; padding: 2rem; background: #f3f4f6; border: 1px solid var(--line); border-radius: var(--radius-card); box-shadow: var(--shadow-soft); }
  .detail-panel { overflow: hidden; min-height: 22rem; display: grid; place-items: center; }
  .detail-panel img { display: block; width: 100%; height: 100%; object-fit: cover; }
  .placeholder { min-height: 100%; width: 100%; display: grid; place-items: center; align-content: center; gap: 0.6rem; padding: 2rem; color: var(--muted); text-align: center; background: radial-gradient(circle at top left, rgba(185, 28, 28, 0.08), transparent 42%), #f8fafc; }
  .placeholder-kicker { color: var(--accent); text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.72rem; font-weight: 700; }
  .placeholder p { margin: 0; max-width: 18rem; line-height: 1.7; }
  .content-card { margin-top: 2rem; padding: 2rem; }
  .action-card h2 { margin: 0.35rem 0 0.75rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 1; }
  .action-card p { color: var(--muted); line-height: 1.8; max-width: 42rem; }
  .action-row { display: flex; flex-wrap: wrap; gap: 0.875rem; margin-top: 1.5rem; }
  .button { display: inline-flex; align-items: center; justify-content: center; min-height: 3rem; padding: 0 1.2rem; border-radius: var(--radius-pill); text-decoration: none; font-weight: 700; }
  .button.primary { background: var(--accent); color: #fff; }
  .button.secondary { border: 1px solid var(--line); color: var(--text); background: transparent; }
  .section-head { max-width: 42rem; margin-bottom: 1rem; }
  .section-head h2 { margin: 0.35rem 0 0; font-size: clamp(2rem, 4vw, 3rem); line-height: 1; }
  .prose-block :global(p) { color: var(--muted); font-size: 1.05rem; line-height: 1.9; }
  @media (max-width: 900px) { .detail-hero { grid-template-columns: 1fr; } }
</style>
