---
import MainLayout from "../../layouts/MainLayout.astro";
import PageCover from "../../components/PageCover.astro";
import { getKnowledgeArticles, getPageBySlug, getSiteSetting } from "../../lib/api";

const [page, siteSetting, articles] = await Promise.all([
  getPageBySlug("conc-knowledge"),
  getSiteSetting(),
  getKnowledgeArticles(),
]);
const title = page?.seo?.metaTitle ?? page?.title ?? "CONC Knowledge | CONC";
const hero = page?.sections?.find((section) => section.type === "hero");
const featuredArticle = articles.find((article) => article.featured) ?? articles[0] ?? null;
const regularArticles = featuredArticle
  ? articles.filter((article) => article.slug !== featuredArticle.slug)
  : articles;
function formatDate(value: string | null) {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return new Intl.DateTimeFormat("en-GB", { day: "2-digit", month: "long", year: "numeric" }).format(date);
}

function formatCategory(value: string | null) {
  if (!value) return "Knowledge";
  return value
    .split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  <section class="border-b border-stone-200 bg-[linear-gradient(135deg,#fffaf0_0%,#ffffff_45%,#f5f5f4_100%)]">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
      <div class="max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Life Long Learning</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">
          {hero?.title ?? "CONC Knowledge"}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
          {hero?.description ??
            "Practical insight, academic perspective, frameworks, and working tools for continuing learning between CONC programs and engagements."}
        </p>
      </div>
      <PageCover eyebrow="CONC Knowledge" title="Articles, frameworks, tools, and reusable learning references" theme="editorial" />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
    {featuredArticle && (
      <article class="grid overflow-hidden rounded-[2rem] border border-stone-200 bg-white shadow-[0_24px_80px_-42px_rgba(41,37,36,0.42)] lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
        <div class="min-h-[18rem] border-r border-stone-200 bg-[#f6f6f4]">
          <div class="flex h-full min-h-[18rem] items-end bg-[#f6f6f4] p-8 text-stone-900">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-red-700">Featured Knowledge</p>
              <p class="mt-3 max-w-sm text-3xl font-semibold leading-tight">{featuredArticle.title}</p>
            </div>
          </div>
        </div>
        <div class="p-8 md:p-10">
          <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">
            <span class="rounded-full bg-red-700 px-3 py-1 text-white">{formatCategory(featuredArticle.category)}</span>
            {formatDate(featuredArticle.publishedDate) && <span>{formatDate(featuredArticle.publishedDate)}</span>}
          </div>
          <h2 class="mt-5 text-3xl font-semibold leading-tight text-stone-900 md:text-4xl">{featuredArticle.title}</h2>
          <p class="mt-5 text-base leading-8 text-stone-600">
            {featuredArticle.summary ??
              featuredArticle.content?.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim().slice(0, 220) ??
              "Published knowledge resource from the CONC editorial system."}
          </p>
          <a class="mt-7 inline-flex items-center text-sm font-semibold text-red-700" href={`/life-long-learning/conc-knowledge/${featuredArticle.slug}`}>
            Read knowledge article
            <span class="ml-2">→</span>
          </a>
        </div>
      </article>
    )}

    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {regularArticles.map((article) => (
        <article class="rounded-[1.75rem] border border-stone-200 bg-white p-7 shadow-sm">
          <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">
            <span class="rounded-full border border-red-700 px-3 py-1 text-red-700">{formatCategory(article.category)}</span>
            {formatDate(article.publishedDate) && <span>{formatDate(article.publishedDate)}</span>}
          </div>
          <h2 class="mt-5 text-2xl font-semibold leading-tight text-stone-900">{article.title}</h2>
          <p class="mt-4 text-sm leading-7 text-stone-600">
            {article.summary ??
              article.content?.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim().slice(0, 160) ??
              "Knowledge resource from CONC."}
          </p>
          <a class="mt-6 inline-flex items-center text-sm font-semibold text-red-700" href={`/life-long-learning/conc-knowledge/${article.slug}`}>
            Read more
            <span class="ml-2">→</span>
          </a>
        </article>
      ))}
    </div>

    {articles.length === 0 && (
      <div class="rounded-[1.75rem] border border-stone-200 bg-white p-8 text-stone-700">
        No CONC Knowledge articles are published yet.
      </div>
    )}
  </section>
</MainLayout>
