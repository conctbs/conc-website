---
import PageCover from "../components/PageCover.astro";
import StructuredPageContent from "../components/StructuredPageContent.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { getPageBySlug, getSiteSetting } from "../lib/api";

const [page, siteSetting] = await Promise.all([getPageBySlug("sitemap"), getSiteSetting()]);
const title = page?.seo?.metaTitle ?? page?.title ?? "Sitemap | CONC";
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  {page ? (
    <StructuredPageContent sections={page.sections} fallbackEyebrow="About Us" fallbackTitle="Sitemap" />
  ) : (
    <section class="border-b border-stone-200 bg-white">
      <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
        <div class="max-w-4xl">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">About Us</p>
          <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">Sitemap</h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
            A direct index of the main public sections and utility routes across the CONC website.
          </p>
        </div>
        <PageCover eyebrow="Sitemap" title="Main routes, supporting pages, and public navigation reference" />
      </div>
    </section>
  )}

  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-6 md:pb-20">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Navigation index</p>
      <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Main public routes</h2>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/">Home</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/about">About</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/about/philosophy">Philosophy</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/about/executive">Executive</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/about/facilities">Facilities</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/services">Services</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/programs">Programs</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/life-long-learning/conc-knowledge">CONC Knowledge</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/projects">Projects</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/news">News</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/contact">Contact</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/sitemap">Sitemap</a>
      <a class="rounded-[1.5rem] border border-stone-200 bg-white px-5 py-4 text-base font-semibold text-stone-900 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.22)] transition hover:-translate-y-1 hover:border-red-700 hover:text-red-700" href="/privacy-policy">Privacy Policy</a>
    </div>
  </section>
</MainLayout>
