---
import PageCover from "../../components/PageCover.astro";
import StructuredPageContent from "../../components/StructuredPageContent.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getPageBySlug, getSiteSetting } from "../../lib/api";

const [page, siteSetting] = await Promise.all([getPageBySlug("client-list"), getSiteSetting()]);
const title = page?.seo?.metaTitle ?? page?.title ?? "Client List | CONC";
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  {page ? (
    <StructuredPageContent sections={page.sections} fallbackEyebrow="Consulting Service" fallbackTitle="Client List" />
  ) : (
    <>
      <section class="border-b border-stone-200 bg-white">
        <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
          <div class="max-w-4xl">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Consulting Service</p>
            <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">Client List</h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
              A public reference page for approved organizations, partner categories, or institutional affiliations associated with CONC work.
            </p>
          </div>
          <PageCover eyebrow="Clients" title="Public references, partner categories, and institutional relationships" theme="services" />
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
        <div class="grid gap-6 md:grid-cols-3">
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6"><p class="text-sm font-semibold text-stone-900">Public sector</p><p class="mt-3 text-sm leading-7 text-stone-600">Government agencies, public institutions, and civic-facing organizations.</p></article>
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6"><p class="text-sm font-semibold text-stone-900">Private sector</p><p class="mt-3 text-sm leading-7 text-stone-600">Business organizations, leadership teams, and operational partners.</p></article>
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6"><p class="text-sm font-semibold text-stone-900">Academic partners</p><p class="mt-3 text-sm leading-7 text-stone-600">Universities, learning institutions, and research-oriented collaborators.</p></article>
        </div>
      </section>
    </>
  )}
</MainLayout>
