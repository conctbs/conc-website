---
const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";

const aboutLinks = [
  { href: "/about", label: "Overview" },
  { href: "/about/philosophy", label: "Philosophy" },
  { href: "/about/executive", label: "Executive" },
  { href: "/about/facilities", label: "Facilities" },
  { href: "/sitemap", label: "Sitemap" },
  { href: "/privacy-policy", label: "Privacy Policy" },
];

const trainingLinks = [
  { href: "/programs", label: "OPEN ENROLLMENT PROGRAMS" },
  { href: "/training-service/customized-training", label: "CUSTOMIZED TRAINING" },
  { href: "/training-service/e-documents", label: "E-Documents" },
  { href: "/training-service/come-teach-with-us", label: "Come teach with us" },
  { href: "/training-service/upload-your-pay-in-slip", label: "Upload your pay-in-slip" },
];

const consultingLinks = [
  { href: "/services", label: "Overview" },
  { href: "/services/service-field", label: "Service Field" },
  { href: "/services/case-method-learning", label: "Case Method Learning" },
  { href: "/services/client-list", label: "Client List" },
  { href: "/services/past-project", label: "Past Project" },
  { href: "/projects", label: "Projects" },
];

const lifelongLinks = [
  { href: "/life-long-learning", label: "Overview" },
  { href: "/life-long-learning/conc-thammasat-forum", label: "CONC Thammasat Forum" },
  { href: "/life-long-learning/past-conc-thammasat-forum", label: "Past CONC Thammasat Forum" },
  { href: "/life-long-learning/conc-knowledge", label: "CONC Knowledge" },
  { href: "/life-long-learning/class-observation", label: "Class Observation" },
];

const newsLinks = [
  { href: "/news", label: "News" },
  { href: "/announcement", label: "Announcement" },
  { href: "/event-calendar", label: "Event Calendar" },
  { href: "/event-programs", label: "Event Programs" },
];

function isCurrentPath(path: string) {
  return currentPath === path;
}

function isSectionActive(paths: { href: string }[]) {
  return paths.some((item) => isCurrentPath(item.href));
}

const aboutActive = isSectionActive(aboutLinks);
const trainingActive = isSectionActive(trainingLinks);
const consultingActive = isSectionActive(consultingLinks);
const lifelongActive = isSectionActive(lifelongLinks);
const newsActive = isSectionActive(newsLinks);
---

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 4px 20px;
    backdrop-filter: blur(18px);
    background: rgba(185, 28, 28, 0.96);
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    flex: 1;
    min-width: 0;
    text-decoration: none;
  }

  .brand img {
    display: block;
    width: 92px;
    height: 92px;
    object-fit: contain;
  }

  .brand-text {
    display: flex;
    align-items: center;
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
    max-width: 320px;
    min-width: 0;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .menu-toggle {
    display: none;
    width: 48px;
    height: 48px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
  }

  .menu-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: 999px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .menu-toggle .bars {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-links {
    display: flex;
    gap: 16px;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-end;
    margin-left: auto;
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    padding-bottom: 12px;
    margin-bottom: -12px;
  }

  .nav-item-shell {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-parent-link,
  .nav-links > a {
    position: relative;
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.1;
  }

  .nav-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto;
    height: auto;
    padding: 0;
    border: 0;
    background: transparent;
    color: #ffffff;
    cursor: pointer;
    font: inherit;
    line-height: 1;
  }

  .nav-trigger::after {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
    transition: transform 0.2s ease;
  }

  nav a:hover,
  .nav-trigger:hover,
  .nav-trigger:focus-visible {
    color: rgba(255, 255, 255, 0.82);
  }

  .nav-links > a.is-active,
  .nav-parent-link.is-active {
    color: #ffffff;
  }

  .nav-links > a.is-active::after,
  .nav-parent-link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.35rem;
    height: 2px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
  }

  .submenu {
    position: absolute;
    top: 100%;
    left: 0;
    display: grid;
    min-width: 220px;
    padding: 0.8rem;
    border: 1px solid rgba(15, 15, 16, 0.08);
    border-radius: 18px;
    background: rgba(243, 244, 246, 0.98);
    box-shadow: 0 20px 40px rgba(15, 15, 16, 0.12);
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .submenu a {
    padding: 0.7rem 0.85rem;
    border-radius: 12px;
    font-size: 0.92rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
  }

  .submenu a:hover {
    background: rgba(185, 28, 28, 0.08);
    color: var(--accent-2);
  }

  .submenu a.is-active {
    background: rgba(185, 28, 28, 0.12);
    color: var(--accent-2);
    font-weight: 800;
  }

  .nav-item.has-submenu:hover .submenu,
  .nav-item.has-submenu:focus-within .submenu,
  .nav-item.has-submenu[data-submenu-open="true"] .submenu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav-item.has-submenu[data-submenu-open="true"] .nav-trigger::after,
  .nav-item.has-submenu:hover .nav-trigger::after,
  .nav-item.has-submenu:focus-within .nav-trigger::after {
    transform: rotate(225deg) translateY(-1px);
  }

  @media (max-width: 1120px) {
    nav {
      align-items: stretch;
      flex-direction: column;
      padding: 4px 12px;
    }

    .nav-shell {
      width: 100%;
    }

    .brand img {
      width: 80px;
      height: 80px;
    }

    .brand-text {
      font-size: 0.8rem;
      max-width: 220px;
    }

    .menu-toggle {
      display: inline-flex;
    }

    .nav-links {
      display: none;
      flex-direction: column;
      gap: 14px;
      align-items: stretch;
      padding-top: 8px;
      border-top: 1px solid rgba(255, 255, 255, 0.18);
      margin-left: 0;
    }

    .nav-item {
      flex-direction: column;
      align-items: stretch;
      padding-bottom: 0;
      margin-bottom: 0;
    }

    .nav-item-shell,
    .nav-parent-link,
    .nav-links > a {
      display: flex;
      align-items: center;
    }

    .nav-item-shell,
    .nav-links > a {
      justify-content: space-between;
      padding: 0.2rem 0;
    }

    .nav-parent-link {
      flex: 1;
      padding: 0.2rem 0;
    }

    .nav-links > a.is-active::after,
    .nav-parent-link.is-active::after {
      bottom: 0;
      left: 0;
      right: auto;
      width: 2.25rem;
    }

    .nav-trigger {
      width: 1.25rem;
      height: 1.25rem;
      flex-shrink: 0;
    }

    .submenu {
      position: static;
      min-width: 0;
      margin-top: 0.5rem;
      padding: 0 0 0 1rem;
      border: 0;
      border-left: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      opacity: 1;
      pointer-events: auto;
      transform: none;
      display: none;
    }

    .submenu a {
      padding: 0.55rem 0;
      color: rgba(255, 255, 255, 0.92);
    }

    .submenu a:hover,
    .submenu a.is-active {
      background: transparent;
      color: #ffffff;
    }

    nav[data-open="true"] .nav-links {
      display: flex;
    }

    .nav-item.has-submenu[data-submenu-open="true"] .submenu {
      display: grid;
    }

    nav[data-open="true"] .menu-toggle span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    nav[data-open="true"] .menu-toggle span:nth-child(2) {
      opacity: 0;
    }

    nav[data-open="true"] .menu-toggle span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }
  }
</style>

<nav data-open="false" id="site-nav">
  <div class="nav-shell">
    <a class="brand" href="/" aria-label="CONC home">
      <img src="/conc-logo.svg" alt="CONC Thammasat Business School logo" />
      <span class="brand-text">CONC Thammasat</span>
    </a>

    <button class="menu-toggle" id="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle navigation">
      <span class="bars">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <div class="nav-links" id="primary-nav">
    <div class="nav-item has-submenu" data-submenu-open="false">
      <div class="nav-item-shell">
        <a class:list={["nav-parent-link", aboutActive && "is-active"]} href="/about" aria-current={isCurrentPath("/about") ? "page" : undefined}>About Us</a>
        <button class="nav-trigger" type="button" aria-expanded="false" aria-controls="about-submenu" aria-label="Toggle About Us menu">
          <span class="sr-only">Open About Us submenu</span>
        </button>
      </div>
      <div class="submenu" id="about-submenu">
        {aboutLinks.map((item) => (
          <a href={item.href} class:list={[isCurrentPath(item.href) && "is-active"]} aria-current={isCurrentPath(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
      </div>
    </div>

    <div class="nav-item has-submenu" data-submenu-open="false">
      <div class="nav-item-shell">
        <a class:list={["nav-parent-link", trainingActive && "is-active"]} href="/programs" aria-current={isCurrentPath("/programs") ? "page" : undefined}>Training Service</a>
        <button class="nav-trigger" type="button" aria-expanded="false" aria-controls="training-submenu" aria-label="Toggle Training Service menu">
          <span class="sr-only">Open Training Service submenu</span>
        </button>
      </div>
      <div class="submenu" id="training-submenu">
        {trainingLinks.map((item) => (
          <a href={item.href} class:list={[isCurrentPath(item.href) && "is-active"]} aria-current={isCurrentPath(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
      </div>
    </div>

    <div class="nav-item has-submenu" data-submenu-open="false">
      <div class="nav-item-shell">
        <a class:list={["nav-parent-link", consultingActive && "is-active"]} href="/services" aria-current={isCurrentPath("/services") ? "page" : undefined}>Consulting Service</a>
        <button class="nav-trigger" type="button" aria-expanded="false" aria-controls="consulting-submenu" aria-label="Toggle Consulting Service menu">
          <span class="sr-only">Open Consulting Service submenu</span>
        </button>
      </div>
      <div class="submenu" id="consulting-submenu">
        {consultingLinks.map((item) => (
          <a href={item.href} class:list={[isCurrentPath(item.href) && "is-active"]} aria-current={isCurrentPath(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
      </div>
    </div>

    <div class="nav-item has-submenu" data-submenu-open="false">
      <div class="nav-item-shell">
        <a class:list={["nav-parent-link", lifelongActive && "is-active"]} href="/life-long-learning" aria-current={isCurrentPath("/life-long-learning") ? "page" : undefined}>Life Long Learning</a>
        <button class="nav-trigger" type="button" aria-expanded="false" aria-controls="lifelong-submenu" aria-label="Toggle Life Long Learning menu">
          <span class="sr-only">Open Life Long Learning submenu</span>
        </button>
      </div>
      <div class="submenu" id="lifelong-submenu">
        {lifelongLinks.map((item) => (
          <a href={item.href} class:list={[isCurrentPath(item.href) && "is-active"]} aria-current={isCurrentPath(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
      </div>
    </div>

    <div class="nav-item has-submenu" data-submenu-open="false">
      <div class="nav-item-shell">
        <a class:list={["nav-parent-link", newsActive && "is-active"]} href="/news" aria-current={isCurrentPath("/news") ? "page" : undefined}>News &amp; Events</a>
        <button class="nav-trigger" type="button" aria-expanded="false" aria-controls="news-submenu" aria-label="Toggle News and Events menu">
          <span class="sr-only">Open News and Events submenu</span>
        </button>
      </div>
      <div class="submenu" id="news-submenu">
        {newsLinks.map((item) => (
          <a href={item.href} class:list={[isCurrentPath(item.href) && "is-active"]} aria-current={isCurrentPath(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
      </div>
    </div>

    <a href="/contact" class:list={[isCurrentPath("/contact") && "is-active"]} aria-current={isCurrentPath("/contact") ? "page" : undefined}>Contact</a>

  </div>
</nav>

<script is:inline>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('menu-toggle');
  const links = document.querySelectorAll('#primary-nav a');
  const submenuItems = Array.from(document.querySelectorAll('.nav-item.has-submenu'));

  function setOpen(nextOpen) {
    if (!nav || !toggle) return;
    nav.dataset.open = nextOpen ? 'true' : 'false';
    toggle.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
  }

  function setSubmenuOpen(targetItem, nextOpen) {
    if (!targetItem) return;
    const targetTrigger = targetItem.querySelector('.nav-trigger');
    targetItem.dataset.submenuOpen = nextOpen ? 'true' : 'false';
    targetTrigger?.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
  }

  function closeOtherSubmenus(activeItem) {
    submenuItems.forEach((item) => {
      if (item !== activeItem) {
        setSubmenuOpen(item, false);
      }
    });
  }

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.dataset.open === 'true';
    setOpen(!isOpen);
  });

  submenuItems.forEach((item) => {
    const trigger = item.querySelector('.nav-trigger');

    trigger?.addEventListener('click', () => {
      const isOpen = item.dataset.submenuOpen === 'true';
      closeOtherSubmenus(item);
      setSubmenuOpen(item, !isOpen);
    });
  });

  links.forEach((link) => {
    link.addEventListener('click', () => {
      submenuItems.forEach((item) => setSubmenuOpen(item, false));
      if (window.innerWidth <= 1120) {
        setOpen(false);
      }
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 1120) {
      setOpen(false);
      submenuItems.forEach((item) => setSubmenuOpen(item, false));
    }
  });

  document.addEventListener('click', (event) => {
    submenuItems.forEach((item) => {
      if (!item.contains(event.target)) {
        setSubmenuOpen(item, false);
      }
    });
  });
</script>
