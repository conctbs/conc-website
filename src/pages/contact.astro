---
import MainLayout from "../layouts/MainLayout.astro";
import SectionRenderer from "../components/SectionRenderer.astro";
import UnavailablePage from "../components/UnavailablePage.astro";
import { getPageBySlug, getSiteSetting } from "../lib/api";

const [page, siteSetting] = await Promise.all([getPageBySlug("contact"), getSiteSetting()]);
const title = page?.seo?.metaTitle ?? page?.title ?? siteSetting?.siteName ?? "Contact";
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  {page ? (
    <SectionRenderer sections={page.sections} />
  ) : (
    <UnavailablePage
      eyebrow="Contact Page"
      title="Contact content is not available yet"
      message="The contact route is wired into the new site shell, but its published contact content has not been provided from Strapi yet."
      slug="contact"
    />
  )}
</MainLayout>
