---
import PageCover from "../../components/PageCover.astro";
import StructuredPageContent from "../../components/StructuredPageContent.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getPageBySlug, getSiteSetting } from "../../lib/api";

const [page, siteSetting] = await Promise.all([getPageBySlug("upload-your-pay-in-slip"), getSiteSetting()]);
const title = page?.seo?.metaTitle ?? page?.title ?? "Upload your pay-in-slip | CONC";
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  {page ? (
    <StructuredPageContent sections={page.sections} fallbackEyebrow="Training Service" fallbackTitle="Upload your pay-in-slip" />
  ) : (
    <>
      <section class="border-b border-stone-200 bg-white">
        <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
          <div class="max-w-4xl">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Training Service</p>
            <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">Upload your pay-in-slip</h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
              Submit payment evidence so the team can match a transfer with the correct registration and confirm the next step.
            </p>
          </div>
          <PageCover eyebrow="Payment" title="Transfer confirmation, payment references, and review workflow" theme="services" />
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.95fr)]">
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-7">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Verification</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Prepare the payment evidence before sending it</h2>
            <p class="mt-4 text-base leading-8 text-stone-600">
              This page should explain the accepted file format, reference details, and how finance or operations verifies a submitted pay-in slip.
            </p>
          </article>
          <aside class="rounded-[1.75rem] border border-dashed border-stone-300 bg-stone-50 p-6">
            <p class="text-sm font-semibold text-stone-900">Already registered?</p>
            <p class="mt-3 text-sm leading-7 text-stone-600">Participants who already have a registration record can use the member payment flow for submission and status tracking.</p>
            <a class="mt-5 inline-flex btn-secondary !rounded-md !border-stone-300 !px-6 !py-3 !text-stone-800" href="/member-payment">Open payment page</a>
          </aside>
        </div>
      </section>
    </>
  )}
</MainLayout>
