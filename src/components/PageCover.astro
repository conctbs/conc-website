---
const {
  eyebrow = 'Page cover',
  title = 'Institutional content',
  theme = 'default',
  compact = false,
} = Astro.props as {
  eyebrow?: string;
  title?: string;
  theme?: string;
  compact?: boolean;
};

const hint = `${theme} ${eyebrow} ${title}`.toLowerCase();

let variant = 'default';
if (hint.includes('program') || hint.includes('course') || hint.includes('training') || hint.includes('learning')) {
  variant = 'programs';
} else if (hint.includes('service') || hint.includes('consult') || hint.includes('client')) {
  variant = 'services';
} else if (hint.includes('project') || hint.includes('work') || hint.includes('case study')) {
  variant = 'projects';
} else if (hint.includes('news') || hint.includes('event') || hint.includes('announcement') || hint.includes('forum')) {
  variant = 'editorial';
} else if (hint.includes('about') || hint.includes('contact') || hint.includes('executive') || hint.includes('facilities') || hint.includes('philosophy')) {
  variant = 'institutional';
} else if (hint.includes('privacy') || hint.includes('sitemap')) {
  variant = 'reference';
}

const palette = {
  default: {
    shell: 'bg-gradient-to-br from-stone-100 via-white to-stone-200/80',
    orbA: 'bg-red-200/75',
    orbB: 'bg-stone-300/80',
    orbC: 'bg-white/90',
    ink: 'bg-stone-900',
  },
  programs: {
    shell: 'bg-gradient-to-br from-amber-50 via-white to-red-100/80',
    orbA: 'bg-red-200/75',
    orbB: 'bg-amber-200/80',
    orbC: 'bg-white/90',
    ink: 'bg-stone-900',
  },
  services: {
    shell: 'bg-gradient-to-br from-stone-100 via-white to-slate-200/80',
    orbA: 'bg-slate-300/75',
    orbB: 'bg-red-200/70',
    orbC: 'bg-white/90',
    ink: 'bg-slate-900',
  },
  projects: {
    shell: 'bg-gradient-to-br from-rose-50 via-white to-stone-200/80',
    orbA: 'bg-rose-200/80',
    orbB: 'bg-stone-300/80',
    orbC: 'bg-white/90',
    ink: 'bg-stone-900',
  },
  editorial: {
    shell: 'bg-gradient-to-br from-red-50 via-white to-orange-100/70',
    orbA: 'bg-orange-200/80',
    orbB: 'bg-red-200/80',
    orbC: 'bg-white/90',
    ink: 'bg-stone-900',
  },
  institutional: {
    shell: 'bg-gradient-to-br from-red-50 via-white to-stone-200/80',
    orbA: 'bg-red-200/75',
    orbB: 'bg-stone-300/75',
    orbC: 'bg-white/90',
    ink: 'bg-stone-900',
  },
  reference: {
    shell: 'bg-gradient-to-br from-stone-100 via-white to-zinc-200/80',
    orbA: 'bg-zinc-300/75',
    orbB: 'bg-stone-300/75',
    orbC: 'bg-white/90',
    ink: 'bg-zinc-900',
  },
}[variant];
---

<div
  class:list={[
    'relative overflow-hidden rounded-[1.75rem] border border-stone-200 shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)]',
    palette.shell,
    compact ? 'min-h-[22rem] sm:min-h-[16rem]' : 'min-h-[31rem] sm:min-h-[20rem]',
  ]}
>
  <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(255,255,255,0.72),rgba(255,255,255,0.18))]"></div>
  <div class:list={['absolute -left-10 top-8 h-28 w-28 rounded-full blur-2xl', palette.orbA]}></div>
  <div class:list={['absolute right-4 top-4 h-36 w-36 rounded-full blur-3xl', palette.orbB]}></div>
  <div class:list={['absolute bottom-6 left-1/3 h-24 w-24 rounded-full blur-2xl', palette.orbC]}></div>

  <div class="absolute inset-x-4 top-5 flex items-center justify-between sm:inset-x-6 sm:top-6">
    <div class="h-3 w-24 rounded-full bg-white/80"></div>
    <div class="h-3 w-12 rounded-full bg-white/70"></div>
  </div>

  <div class="absolute inset-x-4 top-14 grid gap-2 sm:inset-x-6 sm:top-16 sm:gap-3 sm:grid-cols-[1.2fr_0.8fr]">
    <div class="rounded-[1.5rem] border border-white/70 bg-white/75 p-5 backdrop-blur">
      <div class="h-3 w-20 rounded-full bg-red-200/90"></div>
      <div class:list={['mt-4 h-5 w-4/5 rounded-full', palette.ink, 'opacity-90']}></div>
      <div class:list={['mt-3 h-5 w-3/5 rounded-full', palette.ink, 'opacity-70']}></div>
      <div class="mt-5 grid grid-cols-3 gap-2">
        <div class="h-12 rounded-2xl bg-white/80"></div>
        <div class="h-12 rounded-2xl bg-white/70"></div>
        <div class="h-12 rounded-2xl bg-white/80"></div>
      </div>
    </div>
    <div class="grid gap-3">
      <div class="rounded-[1.5rem] border border-white/70 bg-white/80 p-4 backdrop-blur">
        <div class="h-3 w-14 rounded-full bg-stone-300/80"></div>
        <div class:list={['mt-4 h-4 w-full rounded-full', palette.ink, 'opacity-70']}></div>
        <div class:list={['mt-3 h-4 w-2/3 rounded-full', palette.ink, 'opacity-50']}></div>
      </div>
      <div class="rounded-[1.5rem] border border-white/70 bg-white/70 p-4 backdrop-blur">
        <div class="flex gap-2">
          <div class="h-10 flex-1 rounded-2xl bg-white/80"></div>
          <div class="h-10 w-12 rounded-2xl bg-red-100/90"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute inset-x-4 bottom-4 rounded-[1.5rem] border border-white/70 bg-white/80 p-4 backdrop-blur sm:inset-x-6 sm:bottom-6 sm:p-5">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">{eyebrow}</p>
    <p class="mt-3 max-w-md text-lg font-semibold leading-tight text-stone-900">{title}</p>
  </div>
</div>

