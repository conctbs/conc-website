---
import PageCover from "../../components/PageCover.astro";
import StructuredPageContent from "../../components/StructuredPageContent.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getPageBySlug, getSiteSetting } from "../../lib/api";

const [page, siteSetting] = await Promise.all([getPageBySlug("e-documents"), getSiteSetting()]);
const title = page?.seo?.metaTitle ?? page?.title ?? "E-Documents | CONC";
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  {page ? (
    <StructuredPageContent sections={page.sections} fallbackEyebrow="Training Service" fallbackTitle="E-Documents" />
  ) : (
    <>
      <section class="border-b border-stone-200 bg-white">
        <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
          <div class="max-w-4xl">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Training Service</p>
            <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">E-Documents</h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
              A central page for forms, downloadable files, and operational documents used across registration, payment, and training delivery.
            </p>
          </div>
          <PageCover eyebrow="Documents" title="Downloadable files, participant references, and operational forms" theme="services" />
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
        <div class="grid gap-6 md:grid-cols-3">
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6">
            <p class="text-sm font-semibold text-stone-900">Registration files</p>
            <p class="mt-3 text-sm leading-7 text-stone-600">Forms and requirements that support program application or participant onboarding.</p>
          </article>
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6">
            <p class="text-sm font-semibold text-stone-900">Payment references</p>
            <p class="mt-3 text-sm leading-7 text-stone-600">Documents that clarify payment instructions, billing references, or confirmation workflows.</p>
          </article>
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6">
            <p class="text-sm font-semibold text-stone-900">Program materials</p>
            <p class="mt-3 text-sm leading-7 text-stone-600">Schedules, participant references, and follow-up documents shared after publication.</p>
          </article>
        </div>
      </section>
    </>
  )}
</MainLayout>
