---
import { Icon } from 'astro-icon/components';
---

<div
  class="hidden border-b border-red-900 bg-neutral-950 px-4 py-2 text-sm text-white md:flex md:items-center md:gap-3 md:px-6"
>
  <a
    class="inline-flex rounded-full bg-red-600 px-2 py-0.5 text-xs font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-red-500"
    href="/contact"
  >
    Contact
  </a>
  <a class="font-medium text-white/90 transition hover:text-white" href="mailto:conc@tbs.tu.ac.th">conc@tbs.tu.ac.th</a>
  <span class="text-white/40">|</span>
  <a class="font-medium text-white/90 transition hover:text-white" href="tel:+66000000000">+66 (0)0 000 0000</a>
  <span class="text-white/40">|</span>
  <a
    class="inline-flex items-center gap-1.5 rounded-full border border-white/25 bg-white/10 px-3 py-1 font-semibold text-white transition hover:border-white/45 hover:bg-white/15"
    href="/member-login"
  >
    <Icon name="tabler:user-circle" class="h-4 w-4 shrink-0" />
    Member Login
  </a>
  <span class="ml-auto text-white/70">Executive education, consulting, and lifelong learning</span>
</div>
