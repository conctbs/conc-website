---
import MainLayout from '../../layouts/MainLayout.astro';
import { getProjectBySlug, getProjectSlugs, getSiteSetting } from '../../lib/api';

export async function getStaticPaths() {
  const slugs = await getProjectSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug = '' } = Astro.params;
const [project, siteSetting] = await Promise.all([getProjectBySlug(slug), getSiteSetting()]);

if (!project) {
  Astro.response.status = 404;
}

function formatDate(value: string | null) {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }).format(date);
}

const completedDate = formatDate(project?.completedDate ?? null);
const pageTitle = project?.seo?.metaTitle ?? project?.title ?? siteSetting?.siteName ?? 'Project';
const pageDescription = project?.seo?.metaDescription ?? project?.summary ?? siteSetting?.siteDescription ?? null;
---

<MainLayout title={pageTitle} seo={project?.seo} siteSetting={siteSetting}>
  {project ? (
    <article class="mx-auto max-w-7xl px-4 py-14 md:px-6 md:py-20">
      <a class="inline-flex text-sm font-semibold text-red-700 transition hover:text-red-800" href="/projects">Back to projects</a>

      <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1.04fr)_minmax(20rem,0.96fr)]">
        <div>
          <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">
            <span class="rounded-full bg-red-700 px-3 py-1 text-white">{project.clientName ?? 'Selected Work'}</span>
            {completedDate && <span>{completedDate}</span>}
          </div>
          <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight text-stone-900 md:text-5xl lg:text-6xl">
            {project.title}
          </h1>
          {pageDescription && <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-600">{pageDescription}</p>}
          {project.services.length > 0 && (
            <div class="mt-7 flex flex-wrap gap-2">
              {project.services.map((service) => (
                <span class="rounded-full border border-stone-200 bg-stone-50 px-3 py-1 text-xs font-medium text-stone-700">
                  {service.name}
                </span>
              ))}
            </div>
          )}
        </div>

        <div class="overflow-hidden rounded-[1.75rem] border border-stone-200 bg-white shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          {project.coverImage?.url ? (
            <img class="h-full w-full object-cover" src={project.coverImage.url} alt={project.coverImage.alternativeText ?? project.title} loading="eager" />
          ) : (
            <div class="grid min-h-[24rem] place-items-center bg-stone-50 p-8 text-center">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Project Visual</p>
                <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">{project.title}</h2>
                <p class="mt-4 max-w-sm text-sm leading-7 text-stone-600">
                  Upload a cover image in Strapi to turn this case study header into a stronger institutional project lead.
                </p>
              </div>
            </div>
          )}
        </div>
      </section>

      {project.content && (
        <section class="mt-10 rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Case Study</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Project context and delivery approach</h2>
          <div
            class="prose prose-stone mt-6 max-w-4xl prose-headings:font-semibold prose-p:leading-8 prose-a:text-red-700"
            set:html={project.content}
          ></div>
        </section>
      )}

      {project.gallery.length > 0 && (
        <section class="mt-6">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Project Gallery</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Selected visuals</h2>
          </div>
          <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {project.gallery.map((image, index) => (
              <figure class="overflow-hidden rounded-[1.75rem] border border-stone-200 bg-white shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
                {image?.url ? (
                  <img class="h-full w-full object-cover" src={image.url} alt={image.alternativeText ?? `${project.title} image ${index + 1}`} loading="lazy" />
                ) : (
                  <div class="flex min-h-[18rem] items-center justify-center bg-stone-50 text-sm text-stone-500">Image slot {index + 1}</div>
                )}
              </figure>
            ))}
          </div>
        </section>
      )}

      <section class="mt-6 rounded-[2rem] border border-neutral-900 bg-neutral-950 px-6 py-10 text-white shadow-[0_28px_80px_-32px_rgba(12,10,9,0.72)] md:px-10">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-500">Next Step</p>
        <h2 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">Looking for a similar delivery model?</h2>
        <p class="mt-5 max-w-3xl text-base leading-8 text-white/70">
          Use this case study as a starting point for discussing scope, content architecture, and rollout priorities.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn-primary !rounded-md !px-7 !py-3.5" href="/contact">Start a Conversation</a>
          <a class="btn-secondary !rounded-md !border-white/20 !bg-white/5 !px-7 !py-3.5 !text-white" href="/services">
            Review Services
          </a>
        </div>
      </section>
    </article>
  ) : (
    <section class="mx-auto max-w-5xl px-4 py-14 md:px-6 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">404</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-5xl">Project not found</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-600">The requested project slug is not available from Strapi.</p>
      <a class="mt-6 inline-flex text-sm font-semibold text-red-700 transition hover:text-red-800" href="/projects">Back to projects</a>
    </section>
  )}
</MainLayout>
