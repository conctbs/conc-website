---
import MainLayout from '../../../layouts/MainLayout.astro';
import PageCover from '../../../components/PageCover.astro';
import { MEMBER_PORTAL_DISABLED, getProgramBySlug, getProgramSlugs, getSiteSetting } from '../../../lib/api';

const programHeroImageBySlug: Record<string, { src: string; alt: string }> = {
  'strategic-content-operations-bootcamp': {
    src: '/programs/strategic-content-operations-bootcamp-hero.png',
    alt: 'Strategic Content Operations Bootcamp course illustration',
  },
  'executive-communication-design-for-digital-teams': {
    src: '/programs/executive-communication-design-for-digital-teams.png',
    alt: 'Executive Communication Design for Digital Teams course illustration',
  },
};

export async function getStaticPaths() {
  const slugs = await getProgramSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug = '' } = Astro.params;
const [siteSetting, program] = await Promise.all([getSiteSetting(), getProgramBySlug(slug)]);
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID ?? '';
const strapiBaseUrl = import.meta.env.PUBLIC_STRAPI_URL ?? 'http://127.0.0.1:1338/api';
const supportEmail = siteSetting?.contactEmail ?? 'contact@conc.th';
const supportPhone = siteSetting?.contactPhone ?? '09-1119-4503';
const registrationAvailable = Boolean(program?.registrationEnabled) && !MEMBER_PORTAL_DISABLED;
const registrationGoalLabel = program?.isForumEvent ? 'What do you want to discuss or learn from this forum?' : 'What do you want to solve?';
const registrationGoalPlaceholder = program?.isForumEvent
  ? 'Briefly describe the issues, questions, or sector context you want to bring into the forum'
  : 'Briefly describe your training objective';
const heroImage = program ? programHeroImageBySlug[program.slug] ?? null : null;

if (!program) {
  Astro.response.status = 404;
}
---

<MainLayout title={program ? `Register | ${program.title}` : 'Register'} siteSetting={siteSetting}>
  {program ? (
    <section class="mx-auto max-w-7xl px-4 py-14 md:px-6 md:py-20">
      <div class="max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Registration</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-5xl lg:text-6xl">
          Register for {program.title}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-600">
          {registrationAvailable
            ? program.isForumEvent
              ? 'Submit your seminar registration details here. The data is stored in Strapi with the selected forum topic, participant profile, and follow-up notes for review.'
              : 'Fill the short form manually or use a Google account to prefill name and email before sending the registration into Strapi.'
            : MEMBER_PORTAL_DISABLED
              ? 'Program registrations are temporarily disabled because the member backend is unavailable. You can still review the program details and contact the team for manual follow-up.'
            : 'Registration is currently closed for this program. You can still review the details or contact the team for the next intake.'}
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(18rem,0.78fr)_minmax(0,1.22fr)]">
        <div class="grid gap-6">
          {heroImage ? (
            <figure class="overflow-hidden rounded-[1.75rem] border border-stone-200 bg-white shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)]">
              <img
                class="h-full w-full object-cover"
                src={heroImage.src}
                alt={heroImage.alt}
                loading="eager"
              />
            </figure>
          ) : (
            <PageCover eyebrow="Registration" title={program.title} theme="programs" />
          )}
          <aside class="rounded-[1.75rem] border border-stone-200 bg-stone-100 p-6 text-stone-900 shadow-[0_28px_80px_-32px_rgba(12,10,9,0.18)]">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Program Summary</p>
            <h2 class="mt-4 text-3xl font-semibold leading-tight">{program.title}</h2>
            <p class="mt-4 text-base leading-8 text-stone-600">{program.summary}</p>
            {program.registrationNote && <p class="mt-4 text-sm leading-7 text-stone-500">{program.registrationNote}</p>}
            <div class="mt-6 grid gap-3">
              <div class="flex items-center justify-between gap-4 rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm">
                <span class="text-stone-500">Date</span>
                <span class="text-right font-medium">{program.dateLabel}</span>
              </div>
              <div class="flex items-center justify-between gap-4 rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm">
                <span class="text-stone-500">Fee</span>
                <span class="text-right font-medium">{program.fee}</span>
              </div>
              <div class="flex items-center justify-between gap-4 rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm">
                <span class="text-stone-500">Location</span>
                <span class="text-right font-medium">{program.location}</span>
              </div>
              <div class="flex items-center justify-between gap-4 rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm">
                <span class="text-stone-500">Format</span>
                <span class="text-right font-medium">{program.format}</span>
              </div>
              <div class="flex items-center justify-between gap-4 rounded-2xl border border-stone-200 bg-white px-4 py-3 text-sm">
                <span class="text-stone-500">Starts</span>
                <span class="text-right font-medium">{program.startsAt ?? 'TBC'}</span>
              </div>
            </div>
          </aside>
        </div>

        <div class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          {registrationAvailable ? (
            <>
              <form id="registration-form" class="grid gap-5">
                <input type="hidden" name="programSlug" value={program.slug} />
                <label class="grid gap-2 font-semibold text-stone-900">
                  <span>Full name</span>
                  <input
                    id="fullName"
                    name="fullName"
                    type="text"
                    required
                    class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                  />
                </label>
                <label class="grid gap-2 font-semibold text-stone-900">
                  <span>Email</span>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                  />
                </label>
                <label class="grid gap-2 font-semibold text-stone-900">
                  <span>Phone</span>
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    required
                    class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                  />
                </label>
                <label class="grid gap-2 font-semibold text-stone-900">
                  <span>Organization</span>
                  <input
                    name="organization"
                    type="text"
                    class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                  />
                </label>
                <label class="grid gap-2 font-semibold text-stone-900">
                  <span>Position / Job title</span>
                  <input
                    name="jobTitle"
                    type="text"
                    class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                  />
                </label>
                <label class="grid gap-2 font-semibold text-stone-900">
                  <span>{registrationGoalLabel}</span>
                  <textarea
                    name="goal"
                    rows="4"
                    placeholder={registrationGoalPlaceholder}
                    class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                  ></textarea>
                </label>
                <label class="grid gap-2 font-semibold text-stone-900">
                  <span>Dietary requirements / accessibility notes</span>
                  <textarea
                    name="dietaryRequirements"
                    rows="3"
                    placeholder="Optional"
                    class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                  ></textarea>
                </label>
                <label class="grid gap-2 font-semibold text-stone-900">
                  <span>Additional note</span>
                  <textarea
                    name="additionalNote"
                    rows="3"
                    placeholder="Anything the team should know before confirming your seat"
                    class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                  ></textarea>
                </label>
                <div class="grid gap-4 rounded-[1.5rem] border border-stone-200 bg-stone-50 p-5">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Registration Type</p>
                    <p class="mt-2 text-sm leading-7 text-stone-600">
                      One member account can submit one main registration per program. Additional registrations are only for another cohort or a module add-on.
                    </p>
                  </div>
                  <label class="grid gap-2 font-semibold text-stone-900">
                    <span>Registration type</span>
                    <select
                      id="registrationKind"
                      name="registrationKind"
                      class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                    >
                      <option value="program">Main program registration</option>
                      <option value="cohort_extension">Additional cohort / รุ่นเพิ่มเติม</option>
                      <option value="module_addon">Module add-on / เพิ่มโมดูล</option>
                    </select>
                  </label>
                  <label id="cohortLabelField" class="hidden grid gap-2 font-semibold text-stone-900">
                    <span>Cohort detail</span>
                    <input
                      id="cohortLabel"
                      name="cohortLabel"
                      type="text"
                      placeholder="Example: Cohort 2, Executive Weekend"
                      class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                    />
                  </label>
                  <label id="moduleLabelField" class="hidden grid gap-2 font-semibold text-stone-900">
                    <span>Module detail</span>
                    <input
                      id="moduleLabel"
                      name="moduleLabel"
                      type="text"
                      placeholder="Example: Module 3, Leadership Practice Lab"
                      class="w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-base text-stone-900 outline-none transition focus:border-red-700"
                    />
                  </label>
                </div>
                <label class="flex items-start gap-3 text-sm leading-6 text-stone-700">
                  <input type="checkbox" name="consent" required class="mt-1 h-4 w-4 rounded border-stone-300 text-red-700 focus:ring-red-700" />
                  <span>I agree to share my details for this registration.</span>
                </label>

                <div class="rounded-[1.5rem] border border-dashed border-stone-300 bg-stone-50 p-5">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Google Account</p>
                  {googleClientId ? (
                    <>
                      <div id="google-signin-button" class="mt-4"></div>
                      <div id="google-account-state" class="mt-4 font-semibold text-red-700" hidden></div>
                    </>
                  ) : (
                    <p class="mt-4 text-sm leading-7 text-stone-600">Set <code>PUBLIC_GOOGLE_CLIENT_ID</code> to enable Google registration.</p>
                  )}
                </div>

                <button class="btn-primary !rounded-md !px-7 !py-3.5 !border-0" type="submit">Submit registration</button>
              </form>

              <div
                id="form-notification"
                class="fixed right-4 top-4 z-40 hidden max-w-[min(28rem,calc(100vw-2rem))] rounded-2xl bg-emerald-700 px-4 py-4 font-semibold leading-6 text-white shadow-[0_18px_40px_rgba(15,15,16,0.18)] data-[type=error]:bg-red-700"
                hidden
                aria-live="polite"
              ></div>
            </>
          ) : MEMBER_PORTAL_DISABLED ? (
            <div class="grid gap-4">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Temporarily unavailable</p>
              <h2 class="text-3xl font-semibold leading-tight text-stone-900">Online registration is paused</h2>
              <p class="max-w-2xl text-base leading-8 text-stone-600">
                The registration and member APIs are offline right now. Contact <a class="font-semibold text-red-700 underline" href={`mailto:${supportEmail}`}>{supportEmail}</a> if you want the team to record your interest manually.
              </p>
              <div class="mt-3 flex flex-wrap gap-3">
                <a class="btn-primary !rounded-md !px-7 !py-3.5" href="/contact">Contact the team</a>
                <a class="btn-secondary !rounded-md !border-stone-300 !px-7 !py-3.5 !text-stone-800" href={`/programs/${program.slug}`}>
                  Back to program details
                </a>
              </div>
            </div>
          ) : (
            <div class="grid gap-4">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Closed</p>
              <h2 class="text-3xl font-semibold leading-tight text-stone-900">Registration is currently closed</h2>
              <p class="max-w-2xl text-base leading-8 text-stone-600">
                Please contact the team if you want to join the next cohort or need a private session for your organization.
              </p>
              {program.seats != null && program.seats > 0 && (
                <p class="text-sm font-semibold uppercase tracking-[0.16em] text-stone-500">
                  Capacity: {program.seats} seats
                </p>
              )}
              <div class="mt-2 grid gap-3">
                <div class="flex items-center justify-between gap-4 rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm">
                  <span class="text-stone-500">Email</span>
                  <a class="text-right font-medium text-red-700 hover:text-red-800" href={`mailto:${supportEmail}`}>{supportEmail}</a>
                </div>
                <div class="flex items-center justify-between gap-4 rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3 text-sm">
                  <span class="text-stone-500">Phone</span>
                  <a class="text-right font-medium text-red-700 hover:text-red-800" href={`tel:${supportPhone.replace(/[^+\d]/g, '')}`}>{supportPhone}</a>
                </div>
              </div>
              <div class="mt-3 flex flex-wrap gap-3">
                <a class="btn-primary !rounded-md !px-7 !py-3.5" href="/contact">Contact the team</a>
                <a class="btn-secondary !rounded-md !border-stone-300 !px-7 !py-3.5 !text-stone-800" href={`/programs/${program.slug}`}>
                  Back to program details
                </a>
              </div>
            </div>
          )}
        </div>
      </div>

      {registrationAvailable && (
        <script is:inline define:vars={{ googleClientId, strapiBaseUrl, programSlug: program.slug }}>
        const form = document.getElementById('registration-form');
        const notification = document.getElementById('form-notification');
        const submitButton = form?.querySelector('button[type="submit"]');
        const nameInput = document.getElementById('fullName');
        const emailInput = document.getElementById('email');
        const phoneInput = document.getElementById('phone');
        const registrationKindInput = document.getElementById('registrationKind');
        const cohortLabelField = document.getElementById('cohortLabelField');
        const moduleLabelField = document.getElementById('moduleLabelField');
        const cohortLabelInput = document.getElementById('cohortLabel');
        const moduleLabelInput = document.getElementById('moduleLabel');
        const googleState = document.getElementById('google-account-state');
        const authTokenStorageKey = 'concMemberToken';
        let googleProfile = null;
        let notificationTimer = null;

        function syncRegistrationKindFields() {
          const registrationKind = registrationKindInput?.value || 'program';
          const showCohort = registrationKind === 'cohort_extension';
          const showModule = registrationKind === 'module_addon';

          cohortLabelField?.classList.toggle('hidden', !showCohort);
          moduleLabelField?.classList.toggle('hidden', !showModule);

          if (cohortLabelInput instanceof HTMLInputElement) {
            cohortLabelInput.required = showCohort;
            if (!showCohort) cohortLabelInput.value = '';
          }

          if (moduleLabelInput instanceof HTMLInputElement) {
            moduleLabelInput.required = showModule;
            if (!showModule) moduleLabelInput.value = '';
          }
        }

        function lockMemberIdentity(profile) {
          if (profile?.fullName && nameInput instanceof HTMLInputElement) {
            nameInput.value = profile.fullName;
            nameInput.readOnly = true;
          }
          if (profile?.email && emailInput instanceof HTMLInputElement) {
            emailInput.value = profile.email;
            emailInput.readOnly = true;
          }
          if (profile?.phone && phoneInput instanceof HTMLInputElement) {
            phoneInput.value = profile.phone;
            phoneInput.readOnly = true;
          }
          showNotification('Member data loaded. Name, email, and phone are tied to your member account.', 'success');
        }

        function showNotification(message, type = 'success') {
          if (!notification) return;
          if (notificationTimer) {
            window.clearTimeout(notificationTimer);
          }

          notification.hidden = false;
          notification.classList.remove('hidden');
          notification.textContent = message;
          notification.dataset.type = type;
          notification.setAttribute('role', type === 'error' ? 'alert' : 'status');

          notificationTimer = window.setTimeout(() => {
            notification.hidden = true;
            notification.classList.add('hidden');
            notification.textContent = '';
            delete notification.dataset.type;
          }, 3200);
        }

        function parseJwt(token) {
          const payload = token.split('.')[1];
          const base64 = payload.replace(/-/g, '+').replace(/_/g, '/');
          return JSON.parse(decodeURIComponent(atob(base64).split('').map((char) => `%${(`00${char.charCodeAt(0).toString(16)}`).slice(-2)}`).join('')));
        }

        window.handleGoogleCredential = (response) => {
          if (!response?.credential) return;
          const profile = parseJwt(response.credential);
          googleProfile = profile;
          if (profile.name) nameInput.value = profile.name;
          if (profile.email) emailInput.value = profile.email;
          if (googleState) {
            googleState.hidden = false;
            googleState.textContent = `Connected Google account: ${profile.email || profile.name || 'Google user'}`;
          }
        };

        if (googleClientId) {
          const script = document.createElement('script');
          script.src = 'https://accounts.google.com/gsi/client';
          script.async = true;
          script.defer = true;
          script.onload = () => {
            if (!window.google?.accounts?.id) return;
            window.google.accounts.id.initialize({
              client_id: googleClientId,
              callback: window.handleGoogleCredential,
            });
            window.google.accounts.id.renderButton(document.getElementById('google-signin-button'), {
              theme: 'outline',
              size: 'large',
              text: 'signin_with',
              shape: 'pill',
              width: 280,
            });
          };
          document.head.appendChild(script);
        }

        syncRegistrationKindFields();
        registrationKindInput?.addEventListener('change', syncRegistrationKindFields);

        const existingMemberToken = window.localStorage.getItem(authTokenStorageKey);
        if (existingMemberToken) {
          fetch(`${String(strapiBaseUrl).replace(/\/+$/, '')}/member-accounts/me-public`, {
            headers: {
              Authorization: `Bearer ${existingMemberToken}`,
            },
          })
            .then(async (response) => {
              const result = await response.json().catch(() => ({}));
              if (!response.ok || !result?.data?.member) {
                throw new Error('Member session is no longer valid');
              }

              lockMemberIdentity(result.data.member);
            })
            .catch(() => {
              window.localStorage.removeItem(authTokenStorageKey);
            });
        }

        form?.addEventListener('submit', async (event) => {
          event.preventDefault();
          if (notification) {
            notification.hidden = true;
            notification.classList.add('hidden');
            notification.textContent = '';
            delete notification.dataset.type;
          }
          if (submitButton) {
            submitButton.disabled = true;
            submitButton.textContent = 'Submitting...';
          }

          const formData = new FormData(form);
          const payload = Object.fromEntries(formData.entries());
          payload.googleEmail = googleProfile?.email || '';

          try {
            const response = await fetch(`${String(strapiBaseUrl).replace(/\/+$/, '')}/program-registrations/public`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                ...(existingMemberToken ? { Authorization: `Bearer ${existingMemberToken}` } : {}),
              },
              body: JSON.stringify({ data: payload }),
            });

            const result = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(result?.error?.message || result?.message || 'Registration failed');
            }

            form.reset();
            googleProfile = null;
            if (googleState) {
              googleState.hidden = true;
              googleState.textContent = '';
            }
            if (result?.data?.memberAuth?.token) {
              window.localStorage.setItem(authTokenStorageKey, result.data.memberAuth.token);
            }
            const registrationId = result?.data?.id;
            window.__concConsent?.trackAdsConversion({
              value: 1,
              currency: 'THB',
              transaction_id: registrationId ? String(registrationId) : `${programSlug}-${Date.now()}`,
              registration_id: registrationId ? String(registrationId) : '',
              program_slug: programSlug,
              registration_kind: String(payload.registrationKind || 'program'),
            });
            showNotification('Registration submitted. Redirecting you to the payment page.', 'success');
            window.setTimeout(() => {
              window.location.href = registrationId ? `/member-payment?registrationId=${encodeURIComponent(String(registrationId))}` : '/member-portal';
            }, 1400);
          } catch (error) {
            showNotification(error instanceof Error ? error.message : 'Registration failed', 'error');
          } finally {
            if (submitButton) {
              submitButton.disabled = false;
              submitButton.textContent = 'Submit registration';
            }
          }
        });
        </script>
      )}
    </section>
  ) : (
    <section class="mx-auto max-w-5xl px-4 py-14 md:px-6 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">404</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-5xl">Registration page not found</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-600">The requested program is not available.</p>
    </section>
  )}
</MainLayout>
