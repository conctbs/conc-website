---
import PageCover from "../../components/PageCover.astro";
import StructuredPageContent from "../../components/StructuredPageContent.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getPageBySlug, getSiteSetting } from "../../lib/api";

const [page, siteSetting] = await Promise.all([getPageBySlug("facilities"), getSiteSetting()]);
const title = page?.seo?.metaTitle ?? page?.title ?? "Facilities | CONC";
---

<MainLayout title={title} seo={page?.seo} siteSetting={siteSetting}>
  {page ? (
    <StructuredPageContent sections={page.sections} fallbackEyebrow="About Us" fallbackTitle="Facilities" />
  ) : (
    <>
      <section class="border-b border-stone-200 bg-white">
        <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:px-6 md:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end">
          <div class="max-w-4xl">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">About Us</p>
            <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-6xl">Facilities</h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-700">
              Information about the spaces, rooms, and physical environment used for CONC activities and program delivery.
            </p>
          </div>
          <PageCover eyebrow="Facilities" title="Training rooms, meeting environments, and session support spaces" />
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-14 md:px-6">
        <div class="grid gap-6 md:grid-cols-3">
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6"><p class="text-sm font-semibold text-stone-900">Training rooms</p><p class="mt-3 text-sm leading-7 text-stone-600">Spaces configured for seminars, workshops, and structured learning sessions.</p></article>
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6"><p class="text-sm font-semibold text-stone-900">Meeting environments</p><p class="mt-3 text-sm leading-7 text-stone-600">Areas used for executive discussion, planning, and partner consultation.</p></article>
          <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6"><p class="text-sm font-semibold text-stone-900">Operational support</p><p class="mt-3 text-sm leading-7 text-stone-600">Physical setup that supports delivery, coordination, and participant experience.</p></article>
        </div>
      </section>
    </>
  )}
</MainLayout>
