---
import MainLayout from "../layouts/MainLayout.astro";
import { getSiteSetting } from "../lib/api";

const siteSetting = await getSiteSetting();
const title = siteSetting?.siteName ? `Reset Member Password | ${siteSetting.siteName}` : "Reset Member Password | CONC";
const strapiBaseUrl = import.meta.env.PUBLIC_STRAPI_URL ?? "http://127.0.0.1:1338/api";
---

<MainLayout title={title} siteSetting={siteSetting}>
  <section class="mx-auto max-w-6xl px-4 py-16 md:px-6 md:py-20">
    <div class="grid gap-6 lg:grid-cols-2">
      <article class="rounded-[1.75rem] border border-stone-200 bg-white p-6 shadow-[0_20px_60px_-32px_rgba(41,37,36,0.22)] md:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Reset Access</p>
        <h1 class="mt-4 text-3xl font-semibold leading-tight text-stone-900 md:text-4xl">Request a password reset link</h1>
        <p class="mt-4 text-sm leading-7 text-stone-600">
          Enter the same email used for your program registration. In development, the reset link will be shown immediately on this page.
        </p>

        <form id="member-reset-request-form" class="mt-6 grid gap-4">
          <label class="grid gap-2">
            <span class="text-sm font-medium text-stone-700">Email</span>
            <input
              name="email"
              type="email"
              required
              placeholder="name@example.com"
              class="rounded-2xl border border-stone-300 px-4 py-3 text-stone-900 outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100"
            />
          </label>
          <button class="btn-primary !rounded-md !px-7 !py-3.5 !border-0" type="submit">Request reset link</button>
        </form>

        <div id="member-reset-request-result" class="mt-5 hidden rounded-2xl border border-stone-200 bg-stone-50 px-4 py-4 text-sm leading-7 text-stone-700" hidden></div>
      </article>

      <article class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-6 shadow-[0_20px_60px_-32px_rgba(41,37,36,0.18)] md:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-700">Set New Password</p>
        <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900 md:text-4xl">Use your reset token</h2>
        <p class="mt-4 text-sm leading-7 text-stone-600">
          If you already have a reset token or opened the reset link, set a new password here and you will be signed in automatically.
        </p>

        <form id="member-reset-password-form" class="mt-6 grid gap-4">
          <label class="grid gap-2">
            <span class="text-sm font-medium text-stone-700">Reset token</span>
            <input
              id="member-reset-token"
              name="token"
              type="text"
              required
              class="rounded-2xl border border-stone-300 px-4 py-3 text-stone-900 outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100"
            />
          </label>
          <label class="grid gap-2">
            <span class="text-sm font-medium text-stone-700">New password</span>
            <input
              name="password"
              type="password"
              minlength="8"
              required
              class="rounded-2xl border border-stone-300 px-4 py-3 text-stone-900 outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100"
            />
          </label>
          <label class="grid gap-2">
            <span class="text-sm font-medium text-stone-700">Confirm new password</span>
            <input
              name="passwordConfirmation"
              type="password"
              minlength="8"
              required
              class="rounded-2xl border border-stone-300 px-4 py-3 text-stone-900 outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100"
            />
          </label>
          <button class="btn-primary !rounded-md !px-7 !py-3.5 !border-0" type="submit">Reset password</button>
        </form>

        <div
          id="member-reset-notification"
          class="mt-6 hidden rounded-2xl bg-emerald-700 px-4 py-4 text-sm font-semibold leading-6 text-white data-[type=error]:bg-red-700"
          hidden
          aria-live="polite"
        ></div>
      </article>
    </div>
  </section>

  <script is:inline define:vars={{ strapiBaseUrl }}>
    const authTokenStorageKey = 'concMemberToken';
    const params = new URLSearchParams(window.location.search);
    const tokenInput = document.getElementById('member-reset-token');
    const requestForm = document.getElementById('member-reset-request-form');
    const resetForm = document.getElementById('member-reset-password-form');
    const requestResult = document.getElementById('member-reset-request-result');
    const notification = document.getElementById('member-reset-notification');

    if (tokenInput instanceof HTMLInputElement && params.get('token')) {
      tokenInput.value = params.get('token') || '';
    }

    function showNotification(message, type = 'success') {
      if (!notification) return;
      notification.hidden = false;
      notification.classList.remove('hidden');
      notification.dataset.type = type;
      notification.textContent = message;
    }

    function setSubmitting(form, isSubmitting, activeLabel) {
      const button = form?.querySelector('button[type="submit"]');
      if (!(button instanceof HTMLButtonElement)) return;
      if (!button.dataset.defaultLabel) {
        button.dataset.defaultLabel = button.textContent || '';
      }
      button.disabled = isSubmitting;
      button.textContent = isSubmitting ? activeLabel : button.dataset.defaultLabel;
    }

    requestForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      setSubmitting(requestForm, true, 'Requesting...');
      if (requestResult) {
        requestResult.hidden = true;
        requestResult.classList.add('hidden');
        requestResult.innerHTML = '';
      }

      try {
        const response = await fetch(`${String(strapiBaseUrl).replace(/\/+$/, '')}/member-accounts/request-password-reset-public`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ data: Object.fromEntries(new FormData(requestForm).entries()) }),
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result?.data?.sent) {
          throw new Error(result?.error?.message || result?.message || 'Reset request failed');
        }

        const parts = ['Reset request accepted.'];
        if (result.data.expiresAt) {
          parts.push(`Expires: ${new Date(result.data.expiresAt).toLocaleString()}`);
        }
        if (result.data.resetUrl) {
          parts.push(`<a class="font-semibold text-red-700 underline" href="${result.data.resetUrl}">Open reset link</a>`);
        } else if (result.data.resetPath) {
          parts.push(`<a class="font-semibold text-red-700 underline" href="${result.data.resetPath}">Open reset page</a>`);
        }

        if (requestResult) {
          requestResult.hidden = false;
          requestResult.classList.remove('hidden');
          requestResult.innerHTML = parts.join('<br />');
        }
      } catch (error) {
        if (requestResult) {
          requestResult.hidden = false;
          requestResult.classList.remove('hidden');
          requestResult.textContent = error instanceof Error ? error.message : 'Reset request failed';
        }
      } finally {
        setSubmitting(requestForm, false, 'Requesting...');
      }
    });

    resetForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      setSubmitting(resetForm, true, 'Resetting...');
      if (notification) {
        notification.hidden = true;
        notification.classList.add('hidden');
      }

      try {
        const response = await fetch(`${String(strapiBaseUrl).replace(/\/+$/, '')}/member-accounts/reset-password-public`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ data: Object.fromEntries(new FormData(resetForm).entries()) }),
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result?.data?.token) {
          throw new Error(result?.error?.message || result?.message || 'Password reset failed');
        }

        window.localStorage.setItem(authTokenStorageKey, result.data.token);
        showNotification('Password reset complete. Redirecting to your member portal.', 'success');
        window.setTimeout(() => {
          window.location.href = '/member-portal';
        }, 700);
      } catch (error) {
        showNotification(error instanceof Error ? error.message : 'Password reset failed', 'error');
      } finally {
        setSubmitting(resetForm, false, 'Resetting...');
      }
    });
  </script>
</MainLayout>
