---
import MainLayout from '../../layouts/MainLayout.astro';
import { getServiceBySlug, getServiceSlugs, getSiteSetting } from '../../lib/api';

export async function getStaticPaths() {
  const slugs = await getServiceSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug = '' } = Astro.params;
const [service, siteSetting] = await Promise.all([getServiceBySlug(slug), getSiteSetting()]);

if (!service) {
  Astro.response.status = 404;
}

const pageTitle = service?.seo?.metaTitle ?? service?.name ?? siteSetting?.siteName ?? 'Service';
const pageDescription = service?.seo?.metaDescription ?? service?.description ?? siteSetting?.siteDescription ?? null;
---

<MainLayout title={pageTitle} seo={service?.seo} siteSetting={siteSetting}>
  {service ? (
    <article class="mx-auto max-w-7xl px-4 py-14 md:px-6 md:py-20">
      <a class="inline-flex text-sm font-semibold text-red-700 transition hover:text-red-800" href="/services">Back to services</a>

      <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1.06fr)_minmax(20rem,0.94fr)]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Consulting Service</p>
          <h1 class="mt-4 max-w-4xl text-4xl font-semibold leading-tight text-stone-900 md:text-5xl lg:text-6xl">
            {service.name}
          </h1>
          {pageDescription && <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-600">{pageDescription}</p>}
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="btn-primary !rounded-md !px-7 !py-3.5" href="/contact">Contact Us</a>
            <a class="btn-secondary !rounded-md !border-stone-300 !px-7 !py-3.5 !text-stone-800" href="/projects">
              See Related Projects
            </a>
          </div>
        </div>

        <div class="overflow-hidden rounded-[1.75rem] border border-neutral-900 bg-neutral-950 shadow-[0_28px_80px_-32px_rgba(12,10,9,0.72)]">
          {service.icon?.url ? (
            <img src={service.icon.url} alt={service.icon.alternativeText ?? service.name} loading="eager" class="h-full w-full object-cover" />
          ) : (
            <div class="grid min-h-[24rem] place-items-center p-8 text-center text-white">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-500">Service</p>
                <strong class="mt-4 block text-3xl font-semibold">{service.name}</strong>
                <p class="mt-4 max-w-sm text-sm leading-7 text-white/70">
                  Media can be connected from Strapi later without changing this layout.
                </p>
              </div>
            </div>
          )}
        </div>
      </section>

      <section class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.95fr)]">
        <article class="rounded-[1.75rem] border border-stone-200 bg-white p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.38)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Overview</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">What this service covers</h2>
          <p class="mt-6 max-w-3xl text-base leading-8 text-stone-600">{service.description ?? 'No service description is available yet.'}</p>
        </article>

        <aside class="rounded-[1.75rem] border border-stone-200 bg-stone-50 p-8 shadow-[0_20px_60px_-34px_rgba(41,37,36,0.18)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">Delivery note</p>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-stone-900">Best used as a scoped engagement</h2>
          <p class="mt-6 text-base leading-8 text-stone-600">
            Use the contact route to discuss delivery scope, CMS structure, and implementation priorities.
          </p>
        </aside>
      </section>

      <section class="mt-6 rounded-[2rem] border border-neutral-900 bg-neutral-950 px-6 py-10 text-white shadow-[0_28px_80px_-32px_rgba(12,10,9,0.72)] md:px-10">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-500">Next Step</p>
        <h2 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">Need this capability in your stack?</h2>
        <p class="mt-5 max-w-3xl text-base leading-8 text-white/70">
          Start with the service intent, then shape the implementation path around content, platform, and team workflow.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn-primary !rounded-md !px-7 !py-3.5" href="/contact">Contact Us</a>
          <a class="btn-secondary !rounded-md !border-white/20 !bg-white/5 !px-7 !py-3.5 !text-white" href="/projects">
            See Related Projects
          </a>
        </div>
      </section>
    </article>
  ) : (
    <section class="mx-auto max-w-5xl px-4 py-14 md:px-6 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-700">404</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-stone-900 md:text-5xl">Service not found</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-600">The requested service slug is not available from Strapi.</p>
    </section>
  )}
</MainLayout>
